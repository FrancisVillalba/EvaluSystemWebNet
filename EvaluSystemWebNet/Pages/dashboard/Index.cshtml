@page
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveMenu"] = "dashboard";
    ViewData["ShellClass"] = "dashboard-shell";
}

<section class="dashboard-main">
            <header class="dashboard-header">
                <div>
                    <p class="eyebrow">Operacion diaria</p>
                    <h1>Tablero de impresion</h1>
                    <p>Resumen actualizado de ventas, pedidos y cola de produccion.</p>
                </div>
                <button class="primary-button" type="button" onclick="window.location.href='/pedidos'">Nuevo pedido</button>
            </header>

            <section class="metric-grid" aria-label="Resumen de pedidos">
                <article class="metric-card metric-blue">
                    <span>Pedidos cargados hoy</span>
                    <strong id="metric-loaded-today">0</strong>
                    <small>Total ingresado por ventas</small>
                </article>
                <article class="metric-card metric-green">
                    <span>Impresos</span>
                    <strong id="metric-printed">0</strong>
                    <small>Pedidos ya producidos</small>
                </article>
                <article class="metric-card metric-red">
                    <span>Faltan imprimir</span>
                    <strong id="metric-missing-print">0</strong>
                    <small>Pendientes de produccion</small>
                </article>
                <article class="metric-card metric-yellow">
                    <span>Entregados</span>
                    <strong id="metric-delivered">0 / 0</strong>
                    <small>50 entregados de 60 pedidos</small>
                </article>
            </section>

            <section class="panel orders-panel">
                <div class="panel-heading">
                    <div>
                        <h2>Pedidos recientes</h2>
                        <p>Seguimiento desde ventas hasta impresion.</p>
                    </div>
                    <label class="order-search" for="order-search">
                        Buscar pedido
                        <input id="order-search" type="search" placeholder="Vendedor, cliente o tipo" />
                    </label>
                </div>

                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Pedido</th>
                                <th>Cliente</th>
                                <th>Vendedor</th>
                                <th>Tipo</th>
                                <th>Metros</th>
                                <th>Estado</th>
                                <th>Entrega</th>
                            </tr>
                        </thead>
                        <tbody id="dashboard-orders-body"></tbody>
                    </table>
                </div>

                <div class="orders-pagination">
                    <span id="dashboard-pagination-summary">Pagina 1 de 1</span>
                    <div>
                        <label class="page-size-control" for="dashboard-page-size">
                            Registros
                            <select id="dashboard-page-size">
                                <option value="5">5</option>
                                <option value="10" selected>10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="80">80</option>
                                <option value="100">100</option>
                            </select>
                        </label>
                        <button id="dashboard-prev-page" type="button">Anterior</button>
                        <strong id="dashboard-current-page">1</strong>
                        <button id="dashboard-next-page" type="button">Siguiente</button>
                    </div>
                </div>
            </section>
</section>

@section Scripts {
    <script>
        const searchInput = document.getElementById("order-search");
        const ordersBody = document.getElementById("dashboard-orders-body");
        const paginationSummary = document.getElementById("dashboard-pagination-summary");
        const currentPageLabel = document.getElementById("dashboard-current-page");
        const prevPageButton = document.getElementById("dashboard-prev-page");
        const nextPageButton = document.getElementById("dashboard-next-page");
        const pageSizeSelect = document.getElementById("dashboard-page-size");
        let rows = [];
        let currentPage = 1;
        let pageSize = 10;
        let totalPages = 1;
        let searchDebounce;

        function statusClass(status) {
            return status.toLowerCase().replaceAll(" ", "-");
        }

        async function loadDashboard() {
            const search = encodeURIComponent(searchInput.value.trim());
            const response = await fetch(`/api/dashboard?page=${currentPage}&pageSize=${pageSize}&search=${search}`);
            if (!response.ok) {
                showToast("No se pudo cargar el dashboard. Verifique que la API EvaluSystemBack este levantada y que haya iniciado sesion.", "error");
                return;
            }
            const dashboard = await response.json();
            currentPage = dashboard.page || currentPage;
            totalPages = Math.max(dashboard.totalPages || 1, 1);

            document.getElementById("metric-loaded-today").textContent = dashboard.metrics.loadedToday;
            document.getElementById("metric-printed").textContent = dashboard.metrics.printed;
            document.getElementById("metric-missing-print").textContent = dashboard.metrics.missingPrint;
            document.getElementById("metric-delivered").textContent = dashboard.metrics.delivered;

            ordersBody.innerHTML = dashboard.recentOrders.map(order => `
                <tr>
                    <td>${order.id}</td>
                    <td>${order.client}</td>
                    <td>${order.seller}</td>
                    <td>${order.type}</td>
                    <td>${order.meters}</td>
                    <td><span class="status ${statusClass(order.status)}">${order.status}</span></td>
                    <td>${order.delivery}</td>
                </tr>
            `).join("");

            rows = Array.from(document.querySelectorAll("#dashboard-orders-body tr"));
            paginationSummary.textContent = `Pagina ${currentPage} de ${totalPages}`;
            currentPageLabel.textContent = currentPage;
            prevPageButton.disabled = currentPage <= 1;
            nextPageButton.disabled = currentPage >= totalPages;
        }

        prevPageButton.addEventListener("click", function () {
            if (currentPage <= 1) {
                return;
            }

            currentPage -= 1;
            loadDashboard();
        });

        nextPageButton.addEventListener("click", function () {
            if (currentPage >= totalPages) {
                return;
            }

            currentPage += 1;
            loadDashboard();
        });

        pageSizeSelect.addEventListener("change", function () {
            pageSize = Number(pageSizeSelect.value) || 10;
            currentPage = 1;
            loadDashboard();
        });

        searchInput.addEventListener("input", function () {
            window.clearTimeout(searchDebounce);
            searchDebounce = window.setTimeout(() => {
                currentPage = 1;
                loadDashboard();
            }, 350);
        });
        loadDashboard();
    </script>
}
