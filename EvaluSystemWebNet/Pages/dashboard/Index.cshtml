@page
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveMenu"] = "dashboard";
    ViewData["ShellClass"] = "dashboard-shell";
}

<section class="dashboard-main dashboard-analytics">
    <section class="dashboard-analytics-grid" aria-label="Resumen del sistema de impresiones">
        <article class="analytics-card machine-card">
            <header>
                <h2>Meta mensual de facturacion por maquina</h2>
            </header>
            <div class="machine-dashboard-row">
                <div class="machine-chart-layout">
                    <div class="donut-chart" id="machine-donut">
                        <div>
                            <span>Total</span>
                            <strong id="machine-total"></strong>
                        </div>
                    </div>
                    <ul class="machine-legend" id="machine-legend"></ul>
                </div>
                <div class="machine-goals-grid" id="machine-goals-grid" aria-label="Metas mensuales por maquina"></div>
            </div>
            <p class="chart-caption" id="machine-period-caption">Facturacion mensual contra metas configuradas</p>
        </article>

        <section class="summary-card-grid" aria-label="Indicadores principales">
            <article class="summary-tile tile-green">
                <span class="summary-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M7 3h7l4 4v14H7z" />
                        <path d="M14 3v5h5" />
                        <path d="M9 13h4" />
                        <path d="M9 17h3" />
                        <path d="M17 13v6" />
                        <path d="M14 16h6" />
                    </svg>
                </span>
                <div>
                    <p>PEDIDOS CARGADOS HOY</p>
                    <strong id="metric-loaded-today">0</strong>
                </div>
            </article>

            <article class="summary-tile tile-blue">
                <span class="summary-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M7 8V3h10v5" />
                        <path d="M7 17H5a2 2 0 0 1-2-2v-4a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v4a2 2 0 0 1-2 2h-2" />
                        <path d="M7 14h10v7H7z" />
                    </svg>
                </span>
                <div>
                    <p>PEDIDOS IMPRESOS</p>
                    <strong id="metric-printed">0</strong>
                </div>
            </article>

            <article class="summary-tile tile-orange">
                <span class="summary-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M12 7v5l4 2" />
                        <path d="M21 12a9 9 0 1 1-9-9" />
                        <path d="M12 3v3" />
                    </svg>
                </span>
                <div>
                    <p>PEDIDOS PENDIENTES DE IMPRESIÓN</p>
                    <strong id="metric-missing-print">0</strong>
                </div>
            </article>

            <article class="summary-tile tile-teal">
                <span class="summary-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M3 6h11v10H3z" />
                        <path d="M14 10h4l3 3v3h-7z" />
                        <path d="M7 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
                        <path d="M18 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
                        <path d="m6 11 2 2 4-5" />
                    </svg>
                </span>
                <div>
                    <p>PEDIDOS ENVIADOS</p>
                    <strong id="metric-delivered">0/0</strong>
                </div>
            </article>
        </section>

        <article class="analytics-card bar-card">
            <header>
                <h2>Mejor vendedor del mes</h2>
            </header>
            <div class="bar-chart seller-chart" id="seller-bars"></div>
            <p class="chart-axis-label">Ranking del mes</p>
        </article>

        <article class="analytics-card bar-card">
            <header>
                <h2>Pendientes de pago</h2>
            </header>
            <div class="bar-chart" id="payment-bars"></div>
            <p class="chart-axis-label">Clientes con saldo pendiente</p>
        </article>
    </section>
</section>

@section Scripts {
    <script>
        const chartColors = ["#20b85a", "#0f7cf2", "#ff9800", "#7545c9", "#10aeb8", "#ff2f21", "#e543a4"];

        function formatInteger(value) {
            return Number(value || 0).toLocaleString("es-PY");
        }

        function formatDecimal(value) {
            return Number(value || 0).toLocaleString("es-PY", { maximumFractionDigits: 2 });
        }

        function formatCompactMoney(value) {
            const number = Number(value || 0);
            if (Math.abs(number) >= 1000000) {
                return `${formatDecimal(number / 1000000)}M`;
            }

            return formatDecimal(number);
        }

        function renderTotalDonut(goal) {
            const donut = document.getElementById("machine-donut");
            const legend = document.getElementById("machine-legend");
            const target = Number(goal?.meta || 0);
            const percent = Math.max(Math.min(Number(goal?.porcentaje || 0), 100), 0);

            if (target === 0) {
                donut.style.background = "#edf2f5";
                donut.querySelector("span").textContent = "Sin meta";
                donut.querySelector("strong").textContent = "";
                legend.innerHTML = `<li><span></span><strong>Sin meta configurada</strong></li>`;
                return;
            }

            donut.style.background = `conic-gradient(${chartColors[0]} 0% ${percent}%, #d9e1ea ${percent}% 100%)`;
            donut.querySelector("span").textContent = goal.cumplido ? "Cumplido" : "Falta";
            donut.querySelector("strong").textContent = "";
            legend.innerHTML = `
                <li>
                    <span style="background:${chartColors[0]}"></span>
                    <strong>Vendido</strong>
                </li>
                <li>
                    <span style="background:#d9e1ea"></span>
                    <strong>Falta para meta total</strong>
                </li>
                <li>
                    <span style="background:#07145a"></span>
                    <strong>Meta total</strong>
                </li>`;
        }

        function renderGoalDonuts(items) {
            const container = document.getElementById("machine-goals-grid");
            const goals = items || [];

            container.innerHTML = goals.map((item, index) => {
                const percent = Math.max(Math.min(Number(item.porcentaje || 0), 100), 0);
                const color = chartColors[index % chartColors.length];
                const background = percent > 0
                    ? `conic-gradient(${color} 0% ${percent}%, #d9e1ea ${percent}% 100%)`
                    : "#edf2f5";

                return `
                    <article class="goal-donut-card">
                        <h3>${item.nombre}</h3>
                        <div class="donut-chart donut-chart-small" style="background:${background}">
                            <div>
                                <span>Falta</span>
                                <strong></strong>
                            </div>
                        </div>
                    </article>`;
            }).join("");
        }

        function renderBars(containerId, items, valueKey) {
            const container = document.getElementById(containerId);
            const max = Math.max(...items.map(item => Number(item[valueKey] || 0)), 1);

            if (!items.length) {
                container.innerHTML = `<p class="empty-chart">Sin datos para mostrar</p>`;
                return;
            }

            container.innerHTML = items.map((item, index) => {
                const value = Number(item[valueKey] || 0);
                const width = Math.max((value / max) * 100, 3);
                return `
                    <div class="bar-row">
                        <span title="${item.nombre}">${item.nombre}</span>
                        <div class="bar-track">
                            <i style="width:${width}%; background:${chartColors[index % chartColors.length]}"></i>
                        </div>
                    </div>
                `;
            }).join("");
        }

        async function loadDashboard() {
            const response = await fetch("/api/dashboard");

            if (!response.ok) {
                showToast("No se pudo cargar el dashboard. Verifique que la API EvaluSystemBack este levantada y que haya iniciado sesion.", "error");
                return;
            }

            const dashboard = await response.json();
            const machineGoals = dashboard.metasMensualesPorMaquina || [];
            const totalGoal = dashboard.metaMensualTotal || {};
            const monthLabel = new Date().toLocaleDateString("es-PY", { month: "long", year: "numeric" });

            document.getElementById("metric-loaded-today").textContent = formatInteger(dashboard.pedidosCargados);
            document.getElementById("metric-printed").textContent = formatInteger(dashboard.pedidosImpresos);
            document.getElementById("metric-missing-print").textContent = formatInteger(dashboard.pedidosPendientesImpresion);
            document.getElementById("metric-delivered").textContent = `${formatInteger(dashboard.pedidosEntregados)}/${formatInteger(dashboard.totalPedidos)}`;
            document.getElementById("machine-total").textContent = "";
            document.getElementById("machine-period-caption").textContent = `Facturacion de ${monthLabel} contra metas configuradas`;

            renderTotalDonut(totalGoal);
            renderGoalDonuts(machineGoals);
            renderBars("payment-bars", dashboard.pendientesPago || [], "monto");
            renderBars("seller-bars", dashboard.mejoresVendedores || [], "monto");
        }

        loadDashboard();
    </script>
}
