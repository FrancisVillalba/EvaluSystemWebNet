@page
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Clientes";
    ViewData["ActiveMenu"] = "clientes";
    ViewData["ShellClass"] = "clients-shell";
}

<section class="clients-main">
            <section class="clients-panel" id="client-list-panel">
                <div class="clients-panel-heading">
                    <div>
                        <h2>Clientes cargados</h2>
                        <p id="client-count">0 clientes encontrados</p>
                    </div>
                    <button class="clients-primary" type="button" onclick="window.navigateToApp('/clientes/formulario')">
                        <svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M20 21a8 8 0 0 0-16 0" />
                            <path d="M19 8v6" />
                            <path d="M16 11h6" />
                        </svg>
                        <span>Cargar cliente</span>
                    </button>
                </div>

                <section class="clients-filters" aria-label="Filtros de clientes">
                    <label for="filter-search">
                        Buscar cliente
                        <input id="filter-search" type="search" placeholder="Nombre, documento o correo" />
                    </label>

                    <label for="filter-city">
                        Ciudad
                        <select id="filter-city">
                            <option value="">Todas</option>
                        </select>
                    </label>

                    <label for="filter-carrier">
                        Transportadora
                        <select id="filter-carrier">
                            <option value="">Todas</option>
                        </select>
                    </label>

                    <label for="filter-status">
                        Estado
                        <select id="filter-status">
                            <option value="">Todos</option>
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </label>
                </section>

                <div class="clients-table-wrap">
                    <table class="clients-table">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Documento</th>
                                <th>Telefono</th>
                                <th>Correo</th>
                                <th>Ciudad</th>
                                <th>Transportadora</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="clients-body"></tbody>
                    </table>
                </div>

                <div class="clients-pagination">
                    <span id="client-pagination-summary">Pagina 1 de 1</span>
                    <div>
                        <label class="page-size-control" for="client-page-size">
                            Registros
                            <select id="client-page-size">
                                <option value="5">5</option>
                                <option value="10" selected>10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="80">80</option>
                                <option value="100">100</option>
                            </select>
                        </label>
                        <button id="client-prev-page" type="button">Anterior</button>
                        <strong id="client-current-page">1</strong>
                        <button id="client-next-page" type="button">Siguiente</button>
                    </div>
                </div>
            </section>
</section>

@section Scripts {
    <script>
        let clients = [];
        let currentPage = 1;
        let pageSize = 10;
        let totalPages = 1;
        let totalItems = 0;
        let requestId = 0;

        const count = document.getElementById("client-count");
        const body = document.getElementById("clients-body");
        const searchFilter = document.getElementById("filter-search");
        const cityFilter = document.getElementById("filter-city");
        const carrierFilter = document.getElementById("filter-carrier");
        const statusFilter = document.getElementById("filter-status");
        const paginationSummary = document.getElementById("client-pagination-summary");
        const currentPageLabel = document.getElementById("client-current-page");
        const prevPageButton = document.getElementById("client-prev-page");
        const nextPageButton = document.getElementById("client-next-page");
        const pageSizeSelect = document.getElementById("client-page-size");

        function escapeHtml(value) {
            return String(value ?? "").replace(/[&<>"']/g, character => ({
                "&": "&amp;",
                "<": "&lt;",
                ">": "&gt;",
                "\"": "&quot;",
                "'": "&#039;"
            })[character]);
        }

        function optionMarkup(items, valueKey = "id", labelKey = "nombre") {
            return `<option value="">Todas</option>` + items.map(item => `<option value="${escapeHtml(item[valueKey])}">${escapeHtml(item[labelKey] || item[valueKey])}</option>`).join("");
        }

        function buildClientParams() {
            const params = new URLSearchParams({
                page: currentPage,
                pageSize: pageSize
            });

            if (searchFilter.value.trim()) {
                params.set("search", searchFilter.value.trim());
            }

            if (cityFilter.value) {
                params.set("ciudadId", cityFilter.value);
            }

            if (carrierFilter.value) {
                params.set("transportadoraId", carrierFilter.value);
            }

            if (statusFilter.value) {
                params.set("estado", statusFilter.value);
            }

            return params;
        }

        function renderClients() {
            body.innerHTML = clients.map(client => `
                <tr>
                    <td>${escapeHtml(client.name)}</td>
                    <td>${escapeHtml(client.document)}</td>
                    <td>${escapeHtml(client.phone)}</td>
                    <td>${escapeHtml(client.email)}</td>
                    <td>${escapeHtml(client.city)}</td>
                    <td><span class="carrier-status ${client.carrier ? "yes" : ""}">${escapeHtml(client.transportadora || "Sin datos")}</span></td>
                    <td><span class="client-status ${client.status.toLowerCase()}">${client.status}</span></td>
                    <td>
                        <div class="client-row-actions">
                            <button type="button" onclick="window.navigateToApp('/clientes/formulario?id=${client.id}')">Ver</button>
                        </div>
                    </td>
                </tr>
            `).join("");
            count.textContent = `${totalItems} clientes encontrados`;
            paginationSummary.textContent = `Pagina ${currentPage} de ${totalPages}`;
            currentPageLabel.textContent = currentPage;
            prevPageButton.disabled = currentPage <= 1;
            nextPageButton.disabled = currentPage >= totalPages;
        }

        async function deleteClient(id) {
            const confirmed = await showAppConfirm({
                title: "Eliminar cliente",
                message: "Seguro que desea eliminar este cliente?",
                confirmText: "Eliminar",
                cancelText: "Cancelar",
                danger: true
            });

            if (!confirmed) {
                return;
            }

            const response = await withAppLoading("Eliminando cliente...", async function () {
                return await fetch(`/api/clientes/${id}`, { method: "DELETE" });
            });

            if (!response.ok) {
                showToast("No se pudo eliminar el cliente.", "error");
                return;
            }

            showToast("Cliente eliminado correctamente.", "success");
            await loadClients();
        }

        async function loadClients() {
            const currentRequest = ++requestId;

            await withAppLoading("Cargando clientes...", async function () {
                const response = await fetch(`/api/clientes?${buildClientParams().toString()}`);
                if (!response.ok) {
                    let message = "No se pudo cargar clientes. Verifique que la API EvaluSystemBack este levantada y que haya iniciado sesion.";
                    try {
                        const error = await response.json();
                        message = error.message || message;
                    } catch {
                        // Keep the default message when the response is not JSON.
                    }

                    showToast(message, "error");
                    return;
                }
                const result = await response.json();
                if (currentRequest !== requestId) {
                    return;
                }

                clients = result.items || [];
                currentPage = result.page || currentPage;
                totalPages = Math.max(result.totalPages || 1, 1);
                totalItems = result.totalItems || clients.length;
                renderClients();
            });
        }

        async function loadFilterOptions() {
            const response = await fetch("/api/clientes/opciones");
            if (!response.ok) {
                showToast("No se pudieron cargar los filtros de clientes.", "error");
                return;
            }

            const options = await response.json();
            cityFilter.innerHTML = optionMarkup(options.ciudades || [], "id", "nombre");
            carrierFilter.innerHTML = optionMarkup(options.transportadoras || [], "id", "nombre");
        }

        prevPageButton.addEventListener("click", function () {
            if (currentPage <= 1) {
                return;
            }

            currentPage -= 1;
            loadClients();
        });

        nextPageButton.addEventListener("click", function () {
            if (currentPage >= totalPages) {
                return;
            }

            currentPage += 1;
            loadClients();
        });

        pageSizeSelect.addEventListener("change", function () {
            pageSize = Number(pageSizeSelect.value) || 10;
            currentPage = 1;
            loadClients();
        });

        [searchFilter, cityFilter, carrierFilter, statusFilter].forEach(filter => {
            filter.addEventListener("input", function () {
                currentPage = 1;
                loadClients();
            });
            filter.addEventListener("change", function () {
                currentPage = 1;
                loadClients();
            });
        });

        loadFilterOptions().then(loadClients);
    </script>
}
