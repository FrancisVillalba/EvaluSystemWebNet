@page
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Clientes";
    ViewData["ActiveMenu"] = "clientes";
    ViewData["ShellClass"] = "clients-shell";
}

<section class="clients-main">
            <header class="clients-header">
                <div>
                    <p class="eyebrow">ABM de clientes</p>
                    <h1>Clientes</h1>
                    <p>Clientes cargados, con filtros por busqueda, ciudad y estado.</p>
                </div>
                <button class="clients-primary" type="button" onclick="window.location.href='/clientes/formulario'">Cargar cliente</button>
            </header>

            <section class="clients-panel" id="client-list-panel">
                <div class="clients-panel-heading">
                    <div>
                        <h2>Clientes cargados</h2>
                        <p id="client-count">0 clientes encontrados</p>
                    </div>
                </div>

                <section class="clients-filters" aria-label="Filtros de clientes">
                    <label for="filter-search">
                        Buscar cliente
                        <input id="filter-search" type="search" placeholder="Nombre, documento o correo" />
                    </label>

                    <label for="filter-city">
                        Ciudad
                        <select id="filter-city">
                            <option value="">Todas</option>
                            <option>Asuncion</option>
                            <option>San Lorenzo</option>
                            <option>Luque</option>
                        </select>
                    </label>

                    <label for="filter-status">
                        Estado
                        <select id="filter-status">
                            <option value="">Todos</option>
                            <option>Activo</option>
                            <option>Inactivo</option>
                        </select>
                    </label>
                </section>

                <div class="clients-table-wrap">
                    <table class="clients-table">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Documento</th>
                                <th>Telefono</th>
                                <th>Correo</th>
                                <th>Ciudad</th>
                                <th>Transportadora</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="clients-body"></tbody>
                    </table>
                </div>

                <div class="clients-pagination">
                    <span id="client-pagination-summary">Pagina 1 de 1</span>
                    <div>
                        <label class="page-size-control" for="client-page-size">
                            Registros
                            <select id="client-page-size">
                                <option value="10" selected>10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="80">80</option>
                                <option value="100">100</option>
                            </select>
                        </label>
                        <button id="client-prev-page" type="button">Anterior</button>
                        <strong id="client-current-page">1</strong>
                        <button id="client-next-page" type="button">Siguiente</button>
                    </div>
                </div>
            </section>
</section>

@section Scripts {
    <script>
        let clients = [];
        let currentPage = 1;
        let pageSize = 10;
        let totalPages = 1;

        const count = document.getElementById("client-count");
        const body = document.getElementById("clients-body");
        const searchFilter = document.getElementById("filter-search");
        const cityFilter = document.getElementById("filter-city");
        const statusFilter = document.getElementById("filter-status");
        const paginationSummary = document.getElementById("client-pagination-summary");
        const currentPageLabel = document.getElementById("client-current-page");
        const prevPageButton = document.getElementById("client-prev-page");
        const nextPageButton = document.getElementById("client-next-page");
        const pageSizeSelect = document.getElementById("client-page-size");

        function filteredClients() {
            const search = searchFilter.value.trim().toLowerCase();

            return clients.filter(client => {
                const matchesSearch = !search
                    || client.name.toLowerCase().includes(search)
                    || client.document.toLowerCase().includes(search)
                    || client.email.toLowerCase().includes(search);
                const matchesCity = !cityFilter.value || client.city === cityFilter.value;
                const matchesStatus = !statusFilter.value || client.status === statusFilter.value;
                return matchesSearch && matchesCity && matchesStatus;
            });
        }

        function renderClients() {
            const visibleClients = filteredClients();

            body.innerHTML = visibleClients.map(client => `
                <tr>
                    <td>${client.name}</td>
                    <td>${client.document}</td>
                    <td>${client.phone}</td>
                    <td>${client.email}</td>
                    <td>${client.city}</td>
                    <td><span class="carrier-status ${client.carrier ? "yes" : ""}">${client.carrier ? "Si" : "No"}</span></td>
                    <td><span class="client-status ${client.status.toLowerCase()}">${client.status}</span></td>
                    <td>
                        <div class="client-row-actions">
                            <button type="button" onclick="window.location.href='/clientes/formulario?id=${client.id}'">Editar</button>
                            <button class="delete-client" type="button" onclick="deleteClient(${client.id})">Eliminar</button>
                        </div>
                    </td>
                </tr>
            `).join("");
            count.textContent = `${visibleClients.length} clientes encontrados`;
            paginationSummary.textContent = `Pagina ${currentPage} de ${totalPages}`;
            currentPageLabel.textContent = currentPage;
            prevPageButton.disabled = currentPage <= 1;
            nextPageButton.disabled = currentPage >= totalPages;
        }

        async function deleteClient(id) {
            if (!confirm("Desea eliminar este cliente?")) {
                return;
            }

            const response = await fetch(`/api/clientes/${id}`, {
                method: "DELETE"
            });

            if (!response.ok) {
                showToast("No se pudo eliminar el cliente.", "error");
                return;
            }

            showToast("Cliente eliminado correctamente.", "success");
            await loadClients();
        }

        async function loadClients() {
            const response = await fetch(`/api/clientes?page=${currentPage}&pageSize=${pageSize}`);
            if (!response.ok) {
                showToast("No se pudo cargar clientes. Verifique que la API EvaluSystemBack este levantada y que haya iniciado sesion.", "error");
                return;
            }
            const result = await response.json();
            clients = result.items || [];
            currentPage = result.page || currentPage;
            totalPages = Math.max(result.totalPages || 1, 1);
            renderClients();
        }

        prevPageButton.addEventListener("click", function () {
            if (currentPage <= 1) {
                return;
            }

            currentPage -= 1;
            loadClients();
        });

        nextPageButton.addEventListener("click", function () {
            if (currentPage >= totalPages) {
                return;
            }

            currentPage += 1;
            loadClients();
        });

        pageSizeSelect.addEventListener("change", function () {
            pageSize = Number(pageSizeSelect.value) || 10;
            currentPage = 1;
            loadClients();
        });

        [searchFilter, cityFilter, statusFilter].forEach(filter => {
            filter.addEventListener("input", renderClients);
            filter.addEventListener("change", renderClients);
        });

        loadClients();
    </script>
}
