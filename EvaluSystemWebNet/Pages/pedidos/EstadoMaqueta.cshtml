@page "/pedidos/estado-maqueta"
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Maqueta de estados";
    ViewData["ActiveMenu"] = "pedidos";
    ViewData["ShellClass"] = "state-mock-shell";
}

<section class="state-mock-main">
    <header class="state-mock-header">
        <div>
            <p class="eyebrow">Maqueta de flujo</p>
            <h1>Cambio de estado del pedido</h1>
            <p>Vista de prueba para evaluar botones de accion sin modificar la pantalla de carga.</p>
        </div>
        <button class="back-list-button" type="button" onclick="window.location.href='/pedidos'">Volver a pedidos</button>
    </header>

    <section class="state-mock-card" aria-label="Maqueta de acciones por estado">
        <div class="state-mock-summary">
            <div>
                <span>Pedido</span>
                <strong>#1248</strong>
            </div>
            <div>
                <span>Cliente</span>
                <strong>Imprenta Creativa SRL</strong>
            </div>
            <div>
                <span>Estado actual</span>
                <strong id="state-current-label">Carga</strong>
            </div>
        </div>

        <div class="state-flow" id="state-flow" aria-label="Flujo de estados"></div>

        <div class="state-mock-panel">
            <div>
                <span>Accion disponible</span>
                <strong id="state-action-label">Puede avanzar a impresion</strong>
            </div>
            <p id="state-help-text">Use Siguiente para pasar a impresion cuando los archivos esten completos.</p>
        </div>

        <footer class="state-action-footer">
            <button id="state-back-button" class="state-action-button state-back-button" type="button">Devolver</button>
            <button id="state-save-button" class="state-action-button state-save-button" type="button">Guardar</button>
            <button id="state-next-button" class="state-action-button state-next-button" type="button">Siguiente</button>
            <button id="state-delete-button" class="state-action-button state-delete-button" type="button">Eliminar</button>
        </footer>
    </section>
</section>

@section Scripts {
    <script>
        const states = [
            { id: "carga", label: "Carga", flow: 1, help: "Use Siguiente para pasar a impresion cuando los archivos esten completos." },
            { id: "impresion", label: "Impresion", flow: 2, help: "Puede devolver a carga o avanzar a envio cuando termine la impresion." },
            { id: "envio", label: "Envio", flow: 3, help: "Puede confirmar que el pedido ya fue enviado al cliente." },
            { id: "enviado", label: "Enviado", flow: 4, help: "El pedido ya termino el flujo. Solo queda consultar o guardar cambios administrativos." },
            { id: "eliminado", label: "Eliminado", flow: 5, help: "Este estado representa baja logica del pedido." }
        ];

        let currentIndex = 0;

        const currentLabel = document.getElementById("state-current-label");
        const actionLabel = document.getElementById("state-action-label");
        const helpText = document.getElementById("state-help-text");
        const flow = document.getElementById("state-flow");
        const backButton = document.getElementById("state-back-button");
        const saveButton = document.getElementById("state-save-button");
        const nextButton = document.getElementById("state-next-button");
        const deleteButton = document.getElementById("state-delete-button");

        function renderState() {
            const current = states[currentIndex];
            const previous = states[currentIndex - 1];
            const next = states[currentIndex + 1];

            currentLabel.textContent = current.label;
            helpText.textContent = current.help;
            actionLabel.textContent = current.id === "eliminado"
                ? "Pedido marcado para eliminar"
                : next && current.flow < 4
                    ? `Puede avanzar a ${next.label.toLowerCase()}`
                    : "No tiene siguiente estado";

            flow.innerHTML = states.slice(0, 4).map((state, index) => `
                <div class="state-flow-step ${index < currentIndex ? "is-done" : ""} ${index === currentIndex ? "is-current" : ""}">
                    <span>${state.flow}</span>
                    <strong>${state.label}</strong>
                </div>
            `).join("");

            backButton.disabled = currentIndex === 0 || current.flow >= 4;
            nextButton.disabled = current.flow >= 4;
            deleteButton.disabled = current.id === "eliminado";
            backButton.textContent = previous && current.flow < 4 ? `Devolver a ${previous.label}` : "Devolver";
            nextButton.textContent = next && current.flow < 4 ? `Siguiente a ${next.label}` : "Siguiente";
        }

        backButton.addEventListener("click", function () {
            if (currentIndex > 0) {
                currentIndex -= 1;
                renderState();
                showToast("Estado devuelto correctamente.", "success");
            }
        });

        saveButton.addEventListener("click", function () {
            showToast(`Se guardaria el pedido en estado ${states[currentIndex].label}.`, "success");
        });

        nextButton.addEventListener("click", function () {
            if (currentIndex < 3) {
                currentIndex += 1;
                renderState();
                showToast("Estado avanzado correctamente.", "success");
            }
        });

        deleteButton.addEventListener("click", function () {
            currentIndex = 4;
            renderState();
            showToast("Se marcaria el pedido como eliminado.", "error");
        });

        renderState();
    </script>
}
