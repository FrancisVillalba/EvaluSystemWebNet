@page
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Pedidos";
    ViewData["ActiveMenu"] = "pedidos";
    ViewData["ShellClass"] = "orders-shell";
}

<section class="orders-main">
            <section class="orders-panel">
                <div class="orders-panel-heading">
                    <div>
                        <h2>Pedidos cargados</h2>
                        <p id="order-count">0 pedidos encontrados</p>
                    </div>
                    <div class="panel-heading-actions">
                        <button class="orders-primary" type="button" onclick="openOrder()">
                            <svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 5v14" />
                                <path d="M5 12h14" />
                            </svg>
                            <span>Cargar pedido</span>
                        </button>
                        <button id="download-orders-excel" class="orders-export" type="button">
                            <svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M14 3v4a2 2 0 0 0 2 2h4" />
                                <path d="M5 3h9l6 6v12H5z" />
                                <path d="M8 16h8" />
                                <path d="M8 12h4" />
                            </svg>
                            <span>Excel</span>
                        </button>
                    </div>
                </div>

                <section class="orders-filters" aria-label="Filtros de pedidos">
                    <label for="filter-date-from">
                        Fecha desde
                        <input id="filter-date-from" type="date" />
                    </label>

                    <label for="filter-date-to">
                        Fecha hasta
                        <input id="filter-date-to" type="date" />
                    </label>

                    <label for="filter-client">
                        Cliente
                        <select id="filter-client" class="select2-hidden-select">
                            <option value="">Todos</option>
                        </select>
                        <div id="filter-client-select2" class="client-select2">
                            <button id="filter-client-select2-button" class="client-select2-button" type="button" aria-haspopup="listbox" aria-expanded="false">
                                <span id="filter-client-select2-label">Todos</span>
                            </button>
                            <div id="filter-client-select2-dropdown" class="client-select2-dropdown" hidden>
                                <input id="filter-client-select2-search" class="client-select2-search" type="search" placeholder="Buscar cliente" autocomplete="off" />
                                <div id="filter-client-select2-options" class="client-select2-options" role="listbox"></div>
                            </div>
                        </div>
                    </label>

                    <label for="filter-status">
                        Estado
                        <select id="filter-status">
                            <option value="">Todos</option>
                        </select>
                    </label>

                    <label for="filter-seller">
                        Vendedor
                        <select id="filter-seller">
                            <option value="">Todos</option>
                        </select>
                    </label>
                </section>

                <div id="seller-orders-tabs" class="orders-tabs" hidden>
                    <button class="active" type="button" data-orders-tab="summary">Resumen</button>
                    <button type="button" data-orders-tab="sales">Ventas</button>
                </div>

                <section id="seller-orders-summary-tab" class="orders-tab-panel" hidden>
                    <div id="seller-orders-summary" class="seller-orders-summary"></div>
                </section>

                <section id="seller-orders-sales-tab" class="orders-tab-panel">
                    <div class="orders-table-wrap">
                        <table class="orders-table">
                            <thead>
                                <tr>
                                    <th>Pedido</th>
                                    <th>Fecha carga</th>
                                    <th>Cliente</th>
                                    <th>Vendedor</th>
                                    <th>Metros</th>
                                    <th>Estado</th>
                                    <th>Metodo entrega</th>
                                    <th>Usuario entrega</th>
                                    <th>Entrega</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="orders-body"></tbody>
                        </table>
                    </div>

                    <div class="orders-pagination">
                        <span id="order-pagination-summary">Pagina 1 de 1</span>
                        <div>
                            <label class="page-size-control" for="order-page-size">
                                Registros
                                <select id="order-page-size">
                                    <option value="5">5</option>
                                    <option value="10" selected>10</option>
                                    <option value="20">20</option>
                                    <option value="50">50</option>
                                    <option value="80">80</option>
                                    <option value="100">100</option>
                                </select>
                            </label>
                            <button id="order-prev-page" type="button">Anterior</button>
                            <strong id="order-current-page">1</strong>
                            <button id="order-next-page" type="button">Siguiente</button>
                        </div>
                    </div>
                </section>
            </section>
</section>

<div id="order-form-modal" class="order-form-modal" hidden>
    <div class="order-form-modal-backdrop" data-order-modal-close></div>
    <section class="order-form-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="order-form-modal-title">
        <header class="order-form-modal-header">
            <h2 id="order-form-modal-title">Pedido</h2>
            <button id="order-form-modal-close" type="button" aria-label="Cerrar formulario">×</button>
        </header>
        <iframe id="order-form-frame" title="Formulario de pedido"></iframe>
    </section>
</div>

@section Scripts {
    <script>
        function localDateValue(date = new Date()) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, "0");
            const day = String(date.getDate()).padStart(2, "0");
            return `${year}-${month}-${day}`;
        }

        const today = localDateValue();
        let orders = [];
        let currentPage = 1;
        let pageSize = 10;
        let totalPages = 1;
        let totalItems = 0;
        let filterClients = [];
        let currentUserId = null;
        let canViewAllOrders = false;
        let canViewUserSales = false;
        let ordersRequestId = 0;

        const body = document.getElementById("orders-body");
        const count = document.getElementById("order-count");
        const sellerOrdersTabs = document.getElementById("seller-orders-tabs");
        const sellerOrdersSummaryTab = document.getElementById("seller-orders-summary-tab");
        const sellerOrdersSalesTab = document.getElementById("seller-orders-sales-tab");
        const sellerOrdersSummary = document.getElementById("seller-orders-summary");
        const dateFrom = document.getElementById("filter-date-from");
        const dateTo = document.getElementById("filter-date-to");
        const clientFilter = document.getElementById("filter-client");
        const filterClientSelect2 = document.getElementById("filter-client-select2");
        const filterClientSelect2Button = document.getElementById("filter-client-select2-button");
        const filterClientSelect2Label = document.getElementById("filter-client-select2-label");
        const filterClientSelect2Dropdown = document.getElementById("filter-client-select2-dropdown");
        const filterClientSelect2Search = document.getElementById("filter-client-select2-search");
        const filterClientSelect2Options = document.getElementById("filter-client-select2-options");
        const statusFilter = document.getElementById("filter-status");
        const sellerFilter = document.getElementById("filter-seller");
        const paginationSummary = document.getElementById("order-pagination-summary");
        const currentPageLabel = document.getElementById("order-current-page");
        const prevPageButton = document.getElementById("order-prev-page");
        const nextPageButton = document.getElementById("order-next-page");
        const pageSizeSelect = document.getElementById("order-page-size");
        const downloadOrdersExcelButton = document.getElementById("download-orders-excel");
        const orderFormModal = document.getElementById("order-form-modal");
        const orderFormFrame = document.getElementById("order-form-frame");
        const orderFormModalTitle = document.getElementById("order-form-modal-title");
        const orderFormModalClose = document.getElementById("order-form-modal-close");

        function statusClass(status) {
            return String(status || "")
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, "-")
                .replace(/^-|-$/g, "");
        }

        function escapeHtml(value) {
            return String(value ?? "").replace(/[&<>"']/g, character => ({
                "&": "&amp;",
                "<": "&lt;",
                ">": "&gt;",
                "\"": "&quot;",
                "'": "&#039;"
            })[character]);
        }

        function numberValue(value) {
            return Number(String(value).replace(/\./g, "").replace(",", ".")) || 0;
        }

        function formatMoney(value) {
            return Number(value || 0).toLocaleString("es-PY");
        }

        function orderTypeFromDetails(orderDetails) {
            orderDetails = Array.isArray(orderDetails) ? orderDetails : [];
            const product = orderDetails[0]?.product || "DTF Textil";
            return product.includes("UV") ? "UV DTF" : "DTF Textil";
        }

        function metersFromDetails(orderDetails) {
            orderDetails = Array.isArray(orderDetails) ? orderDetails : [];
            const total = orderDetails.reduce((sum, detail) => sum + numberValue(detail.quantity), 0);
            return total ? `${total} m` : "0 m";
        }

        function sellerColorClass(value) {
            const text = String(value || "").trim().toLowerCase();
            let hash = 0;

            for (let index = 0; index < text.length; index += 1) {
                hash = ((hash << 5) - hash + text.charCodeAt(index)) | 0;
            }

            return `seller-color-${Math.abs(hash) % 7}`;
        }

        function buildFilterParams() {
            const params = new URLSearchParams();
            if (dateFrom.value) {
                params.set("dateFrom", dateFrom.value);
            }

            if (dateTo.value) {
                params.set("dateTo", dateTo.value);
            }

            if (clientFilter.value) {
                params.set("clienteId", clientFilter.value);
            }

            if (statusFilter.value) {
                params.set("estadoVentaId", statusFilter.value);
            }

            if (sellerFilter.value) {
                params.set("vendedorId", sellerFilter.value);
            }

            return params;
        }

        function buildOrderParams(page, size) {
            const params = buildFilterParams();
            params.set("page", page);
            params.set("pageSize", size);
            return params;
        }

        function renderOrders() {
            if (!orders.length) {
                body.innerHTML = `<tr><td colspan="10">No hay pedidos para los filtros seleccionados.</td></tr>`;
            } else {
                body.innerHTML = orders.map(order => {
                    const details = Array.isArray(order.details) ? order.details : [];
                    const deliveryMethod = order.deliveryMethod || "Sin metodo";
                    const sellerName = shortPersonName(order.seller) || order.seller || "-";
                    return `
                <tr>
                    <td>${escapeHtml(order.id)}</td>
                    <td>${escapeHtml(order.date)}</td>
                    <td class="orders-strong">${escapeHtml(order.client)}</td>
                    <td><span class="orders-seller ${sellerColorClass(order.seller)}">${escapeHtml(sellerName)}</span></td>
                    <td>${escapeHtml(metersFromDetails(details))}</td>
                    <td><span class="orders-status ${statusClass(order.status)}">${escapeHtml(order.status)}</span></td>
                    <td><span class="orders-status delivery-method ${statusClass(deliveryMethod)}">${escapeHtml(deliveryMethod)}</span></td>
                    <td>${escapeHtml(shortPersonName(order.deliveryUser) || "-")}</td>
                    <td>${escapeHtml(order.delivery)}</td>
                    <td class="orders-actions">
                        <button class="orders-edit" type="button" onclick="openOrder('${escapeHtml(order.id)}')">Ver</button>
                    </td>
                </tr>
                    `;
                }).join("");
            }

            count.textContent = `${totalItems} pedidos encontrados`;
            paginationSummary.textContent = `Pagina ${currentPage} de ${totalPages}`;
            currentPageLabel.textContent = currentPage;
            prevPageButton.disabled = currentPage <= 1;
            nextPageButton.disabled = currentPage >= totalPages;
        }

        function renderUserSalesSummary(data) {
            if (!data?.puedeVerVentasUsuario) {
                sellerOrdersSummary.innerHTML = "";
                return;
            }

            const totals = data.totales || {};
            sellerOrdersSummary.innerHTML = `
                <div class="seller-summary-metrics">
                    <article class="summary-card-orders">
                        <span>Pedidos</span>
                        <strong>${formatMoney(totals.cantidadPedidos)}</strong>
                    </article>
                    <article class="summary-card-sales">
                        <span>Total venta</span>
                        <strong>${formatMoney(totals.totalVenta)}</strong>
                    </article>
                    <article class="summary-card-meters">
                        <span>Metros</span>
                        <strong>${Number(totals.totalMetros || 0).toLocaleString("es-PY", { maximumFractionDigits: 2 })}</strong>
                    </article>
                    <article class="summary-card-commission">
                        <span>Total comision</span>
                        <strong>${formatMoney(totals.totalComision)}</strong>
                    </article>
                </div>`;
        }

        async function loadUserSalesSummary() {
            if (!canViewUserSales) {
                return;
            }

            const params = buildFilterParams();

            const response = await fetch(`/api/pedidos/mis-ventas?${params}`);
            if (!response.ok) {
                showToast("No se pudo cargar el resumen de ventas.", "error");
                return;
            }

            renderUserSalesSummary(await response.json());
        }

        function openOrder(id = "") {
            const hasId = Boolean(id);
            orderFormModalTitle.textContent = hasId ? `Pedido ${id}` : "Nuevo pedido";
            orderFormFrame.src = hasId
                ? `/pedidos/formulario?id=${encodeURIComponent(id)}&embedded=1`
                : "/pedidos/formulario?embedded=1";
            orderFormModal.hidden = false;
            document.body.classList.add("is-order-modal-open");
            orderFormModalClose.focus();
        }

        function closeOrderModal(shouldRefresh = false) {
            orderFormModal.hidden = true;
            orderFormFrame.src = "about:blank";
            document.body.classList.remove("is-order-modal-open");

            if (shouldRefresh) {
                loadOrders();
            }
        }

        function optionMarkup(items, valueKey, labelKey) {
            return `<option value="">Todos</option>` + items.map(item => {
                const value = item[valueKey] ?? "";
                const label = item[labelKey] || value;
                return `<option value="${value}">${label}</option>`;
            }).join("");
        }

        function clientOptionLabel(client) {
            return client.documento
                ? `${client.nombre || `Cliente ${client.id}`} - ${client.documento}`
                : client.nombre || `Cliente ${client.id}`;
        }

        function sellerOptionLabel(seller) {
            return seller.persona || seller.nombreUsuario || `Usuario ${seller.id}`;
        }

        function shortPersonName(value) {
            const parts = String(value || "").trim().split(/\s+/).filter(Boolean);
            if (parts.length >= 3) {
                return `${parts[0]} ${parts[2]}`;
            }

            return parts.length > 1 ? `${parts[0]} ${parts[1]}` : parts[0] || "";
        }

        function sellerOptionMarkup(items) {
            const allOption = canViewAllOrders ? `<option value="">Todos</option>` : "";
            return allOption + items.map(item => {
                const value = item.id ?? "";
                return `<option value="${escapeHtml(value)}">${escapeHtml(sellerOptionLabel(item))}</option>`;
            }).join("");
        }

        function updateFilterClientSelect2Label() {
            const selectedClient = filterClients.find(client => String(client.id) === String(clientFilter.value));
            filterClientSelect2Label.textContent = selectedClient ? clientOptionLabel(selectedClient) : "Todos";
        }

        function renderFilterClientSelect2Options() {
            const search = filterClientSelect2Search.value.trim().toLowerCase();
            const selected = String(clientFilter.value || "");
            const clients = filterClients.filter(client => {
                const text = `${client.nombre || ""} ${client.documento || ""}`.toLowerCase();
                return !search || text.includes(search);
            });

            const allOption = `<button class="client-select2-option${selected ? "" : " is-selected"}" type="button" role="option" data-value="">Todos</button>`;
            const clientOptions = clients.map(client => {
                const value = String(client.id);
                const isSelected = value === selected ? " is-selected" : "";
                return `<button class="client-select2-option${isSelected}" type="button" role="option" data-value="${escapeHtml(value)}">${escapeHtml(clientOptionLabel(client))}</button>`;
            }).join("");

            const hasVisibleOptions = Boolean(clientOptions) || !search;
            filterClientSelect2Options.innerHTML = hasVisibleOptions
                ? allOption + clientOptions
                : `<div class="client-select2-empty">Sin resultados</div>`;
        }

        function setFilterClientSelect2Open(isOpen) {
            filterClientSelect2Dropdown.hidden = !isOpen;
            filterClientSelect2Button.setAttribute("aria-expanded", String(isOpen));

            if (isOpen) {
                filterClientSelect2Search.value = "";
                filterClientSelect2Search.focus();
                renderFilterClientSelect2Options();
            }
        }

        async function loadFilterOptions() {
            await withAppLoading("Cargando filtros...", async function () {
                const response = await fetch("/api/pedidos/opciones");
                if (!response.ok) {
                    showToast("No se pudieron cargar los filtros desde la base de datos.", "error");
                    return;
                }

                const options = await response.json();
                filterClients = options.clientes || [];
                currentUserId = options.usuarioActualId || null;
                canViewAllOrders = options.puedeVerTodosPedidos === true;
                canViewUserSales = options.puedeVerVentasUsuario === true;
                sellerOrdersTabs.hidden = !canViewUserSales;
                sellerOrdersSummaryTab.hidden = !canViewUserSales;
                sellerOrdersSalesTab.hidden = canViewUserSales;
                clientFilter.innerHTML = optionMarkup(filterClients, "id", "nombre");
                updateFilterClientSelect2Label();
                renderFilterClientSelect2Options();
                statusFilter.innerHTML = optionMarkup(options.estadosVenta || [], "id", "nombre");
                sellerFilter.innerHTML = sellerOptionMarkup(options.vendedores || []);

                if (!canViewAllOrders && currentUserId) {
                    sellerFilter.value = String(currentUserId);
                    sellerFilter.disabled = true;
                }
            });
        }

        async function loadOrders() {
            const requestId = ++ordersRequestId;

            await withAppLoading("Cargando pedidos...", async function () {
                const params = buildOrderParams(currentPage, pageSize);

                const response = await fetch(`/api/pedidos?${params.toString()}`);
                if (!response.ok) {
                    showToast("No se pudo cargar pedidos. Verifique que la API EvaluSystemBack este levantada y que haya iniciado sesion.", "error");
                    return;
                }
                const result = await response.json();
                if (requestId !== ordersRequestId) {
                    return;
                }

                orders = result.items || [];
                currentPage = result.page || currentPage;
                totalPages = Math.max(result.totalPages || 1, 1);
                totalItems = result.totalItems || orders.length;
                if (!orders.length && totalItems > 0 && currentPage > totalPages) {
                    currentPage = totalPages;
                    await loadOrders();
                    return;
                }

                renderOrders();
                await loadUserSalesSummary();
            });
        }

        async function downloadFilteredOrdersExcel() {
            await withAppLoading("Preparando Excel...", async function () {
                const response = await fetch(`/api/pedidos/exportar-excel?${buildFilterParams().toString()}`);
                if (!response.ok) {
                    showToast("No se pudo preparar el Excel de pedidos.", "error");
                    return;
                }

                const blob = await response.blob();
                const link = document.createElement("a");
                link.href = URL.createObjectURL(blob);
                link.download = `pedidos-${localDateValue()}.xls`;
                document.body.appendChild(link);
                link.click();
                link.remove();
                URL.revokeObjectURL(link.href);
            });
        }

        prevPageButton.addEventListener("click", function () {
            if (currentPage <= 1) {
                return;
            }

            currentPage -= 1;
            loadOrders();
        });

        nextPageButton.addEventListener("click", function () {
            if (currentPage >= totalPages) {
                return;
            }

            currentPage += 1;
            loadOrders();
        });

        pageSizeSelect.addEventListener("change", function () {
            pageSize = Number(pageSizeSelect.value) || 10;
            currentPage = 1;
            loadOrders();
        });

        downloadOrdersExcelButton.addEventListener("click", downloadFilteredOrdersExcel);
        sellerOrdersTabs.querySelectorAll("button").forEach(button => {
            button.addEventListener("click", function () {
                sellerOrdersTabs.querySelectorAll("button").forEach(item => item.classList.remove("active"));
                button.classList.add("active");
                sellerOrdersSummaryTab.hidden = button.dataset.ordersTab !== "summary";
                sellerOrdersSalesTab.hidden = button.dataset.ordersTab !== "sales";
            });
        });
        orderFormModalClose.addEventListener("click", () => closeOrderModal());
        orderFormModal.addEventListener("click", function (event) {
            if (event.target.closest("[data-order-modal-close]")) {
                closeOrderModal();
            }
        });

        window.addEventListener("message", function (event) {
            if (event.origin !== window.location.origin) {
                return;
            }

            if (event.data?.type === "order-modal-close") {
                closeOrderModal();
            }

            if (event.data?.type === "order-modal-saved") {
                closeOrderModal(true);
            }
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape" && !orderFormModal.hidden) {
                closeOrderModal();
            }
        });

        filterClientSelect2Button.addEventListener("click", function () {
            setFilterClientSelect2Open(filterClientSelect2Dropdown.hidden);
        });

        filterClientSelect2Search.addEventListener("input", renderFilterClientSelect2Options);

        filterClientSelect2Options.addEventListener("click", function (event) {
            const option = event.target.closest("[data-value]");
            if (!option) {
                return;
            }

            clientFilter.value = option.dataset.value;
            updateFilterClientSelect2Label();
            renderFilterClientSelect2Options();
            setFilterClientSelect2Open(false);
            currentPage = 1;
            loadOrders();
        });

        document.addEventListener("click", function (event) {
            if (!filterClientSelect2.contains(event.target)) {
                setFilterClientSelect2Open(false);
            }
        });

        [dateFrom, dateTo, clientFilter, statusFilter, sellerFilter].forEach(filter => {
            filter.addEventListener("input", function () {
                currentPage = 1;
                loadOrders();
            });
            filter.addEventListener("change", function () {
                currentPage = 1;
                loadOrders();
            });
        });

        dateFrom.value = today;
        dateTo.value = today;
        loadFilterOptions().then(loadOrders);
    </script>
}
