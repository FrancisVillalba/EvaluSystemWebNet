@page
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Pedidos";
    ViewData["ActiveMenu"] = "pedidos";
    ViewData["ShellClass"] = "orders-shell";
}

<section class="orders-main">
            <header class="orders-header">
                <div>
                    <p class="eyebrow">Lista de pedidos</p>
                    <h1>Pedidos</h1>
                    <p>Pedidos cargados, con filtros por fecha de carga, cliente y estado.</p>
                </div>
                <button class="orders-primary" type="button" onclick="window.location.href='/pedidos/formulario'">Cargar pedido</button>
            </header>

            <section class="orders-panel">
                <div class="orders-panel-heading">
                    <div>
                        <h2>Pedidos cargados en el dia</h2>
                        <p id="order-count">0 pedidos encontrados</p>
                    </div>
                </div>

                <section class="orders-filters" aria-label="Filtros de pedidos">
                    <label for="filter-date-from">
                        Fecha desde
                        <input id="filter-date-from" type="date" />
                    </label>

                    <label for="filter-date-to">
                        Fecha hasta
                        <input id="filter-date-to" type="date" />
                    </label>

                    <label for="filter-client">
                        Cliente
                        <select id="filter-client">
                            <option value="">Todos</option>
                        </select>
                    </label>

                    <label for="filter-status">
                        Estado
                        <select id="filter-status">
                            <option value="">Todos</option>
                        </select>
                    </label>
                </section>

                <div class="orders-table-wrap">
                    <table class="orders-table">
                        <thead>
                            <tr>
                                <th>Pedido</th>
                                <th>Fecha carga</th>
                                <th>Cliente</th>
                                <th>Vendedor</th>
                                <th>Tipo</th>
                                <th>Metros</th>
                                <th>Estado</th>
                                <th>Entrega</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="orders-body"></tbody>
                    </table>
                </div>

                <div class="orders-pagination">
                    <span id="order-pagination-summary">Pagina 1 de 1</span>
                    <div>
                        <label class="page-size-control" for="order-page-size">
                            Registros
                            <select id="order-page-size">
                                <option value="5">5</option>
                                <option value="10" selected>10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="80">80</option>
                                <option value="100">100</option>
                            </select>
                        </label>
                        <button id="order-prev-page" type="button">Anterior</button>
                        <strong id="order-current-page">1</strong>
                        <button id="order-next-page" type="button">Siguiente</button>
                    </div>
                </div>
            </section>
</section>

@section Scripts {
    <script>
        function localDateValue(date = new Date()) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, "0");
            const day = String(date.getDate()).padStart(2, "0");
            return `${year}-${month}-${day}`;
        }

        const today = localDateValue();
        let orders = [];
        let currentPage = 1;
        let pageSize = 10;
        let totalPages = 1;
        let totalItems = 0;

        const body = document.getElementById("orders-body");
        const count = document.getElementById("order-count");
        const dateFrom = document.getElementById("filter-date-from");
        const dateTo = document.getElementById("filter-date-to");
        const clientFilter = document.getElementById("filter-client");
        const statusFilter = document.getElementById("filter-status");
        const paginationSummary = document.getElementById("order-pagination-summary");
        const currentPageLabel = document.getElementById("order-current-page");
        const prevPageButton = document.getElementById("order-prev-page");
        const nextPageButton = document.getElementById("order-next-page");
        const pageSizeSelect = document.getElementById("order-page-size");

        function statusClass(status) {
            return status.toLowerCase().replaceAll(" ", "-");
        }

        function numberValue(value) {
            return Number(String(value).replace(/\./g, "").replace(",", ".")) || 0;
        }

        function orderTypeFromDetails(orderDetails) {
            const product = orderDetails[0]?.product || "DTF Textil";
            return product.includes("UV") ? "UV DTF" : "DTF Textil";
        }

        function metersFromDetails(orderDetails) {
            const total = orderDetails.reduce((sum, detail) => sum + numberValue(detail.quantity), 0);
            return total ? `${total} m` : "0 m";
        }

        function renderOrders() {
            body.innerHTML = orders.map(order => `
                <tr>
                    <td>${order.id}</td>
                    <td>${order.date}</td>
                    <td>${order.client}</td>
                    <td>${order.seller}</td>
                    <td>${orderTypeFromDetails(order.details)}</td>
                    <td>${metersFromDetails(order.details)}</td>
                    <td><span class="orders-status ${statusClass(order.status)}">${order.status}</span></td>
                    <td>${order.delivery}</td>
                    <td>
                        <button class="orders-edit" type="button" onclick="window.location.href='/pedidos/formulario?id=${order.id}'">Editar</button>
                        <button class="orders-edit" type="button" onclick="deleteOrder('${order.id}')">Eliminar</button>
                    </td>
                </tr>
            `).join("");

            count.textContent = `${totalItems} pedidos encontrados`;
            paginationSummary.textContent = `Pagina ${currentPage} de ${totalPages}`;
            currentPageLabel.textContent = currentPage;
            prevPageButton.disabled = currentPage <= 1;
            nextPageButton.disabled = currentPage >= totalPages;
        }

        function optionMarkup(items, valueKey, labelKey) {
            return `<option value="">Todos</option>` + items.map(item => {
                const value = item[valueKey] ?? "";
                const label = item[labelKey] || value;
                return `<option value="${value}">${label}</option>`;
            }).join("");
        }

        async function loadFilterOptions() {
            const response = await fetch("/api/pedidos/opciones");
            if (!response.ok) {
                showToast("No se pudieron cargar los filtros desde la base de datos.", "error");
                return;
            }

            const options = await response.json();
            clientFilter.innerHTML = optionMarkup(options.clientes || [], "id", "nombre");
            statusFilter.innerHTML = optionMarkup(options.estadosVenta || [], "id", "nombre");
        }

        async function deleteOrder(id) {
            if (!confirm("Desea eliminar este pedido?")) {
                return;
            }

            const response = await fetch(`/api/pedidos/${id}`, {
                method: "DELETE"
            });

            if (!response.ok) {
                showToast("No se pudo eliminar el pedido.", "error");
                return;
            }

            showToast("Pedido eliminado correctamente.", "success");
            await loadOrders();
        }

        async function loadOrders() {
            const params = new URLSearchParams({
                page: currentPage,
                pageSize: pageSize
            });

            if (dateFrom.value) {
                params.set("dateFrom", dateFrom.value);
            }

            if (dateTo.value) {
                params.set("dateTo", dateTo.value);
            }

            if (clientFilter.value) {
                params.set("clienteId", clientFilter.value);
            }

            if (statusFilter.value) {
                params.set("estadoVentaId", statusFilter.value);
            }

            const response = await fetch(`/api/pedidos?${params.toString()}`);
            if (!response.ok) {
                showToast("No se pudo cargar pedidos. Verifique que la API EvaluSystemBack este levantada y que haya iniciado sesion.", "error");
                return;
            }
            const result = await response.json();
            orders = result.items || [];
            currentPage = result.page || currentPage;
            totalPages = Math.max(result.totalPages || 1, 1);
            totalItems = result.totalItems || orders.length;
            renderOrders();
        }

        prevPageButton.addEventListener("click", function () {
            if (currentPage <= 1) {
                return;
            }

            currentPage -= 1;
            loadOrders();
        });

        nextPageButton.addEventListener("click", function () {
            if (currentPage >= totalPages) {
                return;
            }

            currentPage += 1;
            loadOrders();
        });

        pageSizeSelect.addEventListener("change", function () {
            pageSize = Number(pageSizeSelect.value) || 10;
            currentPage = 1;
            loadOrders();
        });

        [dateFrom, dateTo, clientFilter, statusFilter].forEach(filter => {
            filter.addEventListener("input", function () {
                currentPage = 1;
                loadOrders();
            });
            filter.addEventListener("change", function () {
                currentPage = 1;
                loadOrders();
            });
        });

        dateFrom.value = today;
        dateTo.value = today;
        loadFilterOptions().then(loadOrders);
    </script>
}
