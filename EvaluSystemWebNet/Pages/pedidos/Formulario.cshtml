@page
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Crear pedido";
    ViewData["ActiveMenu"] = "pedidos";
    ViewData["ShellClass"] = "entry-shell";
}

<section class="entry-main">
            <header class="entry-header">
                <div>
                    <p class="eyebrow">Carga de ventas impresiones</p>
                    <h1 id="order-form-title">Nuevo pedido</h1>
                    <p>Registra la venta y sus detalles para enviarla a produccion.</p>
                </div>
                <button class="back-list-button" type="button" onclick="window.location.href='/pedidos'">Volver a la lista</button>
            </header>

            <form id="order-form" class="entry-form">
                <input type="hidden" id="order-id" />
                <input type="hidden" id="order-date" />
                <input type="hidden" id="order-status" />

                <section class="entry-section" aria-label="Carga de ventas impresiones">
                    <div class="section-title">Carga de ventas impresiones</div>

                    <div class="entry-fields">
                        <label class="field client-field" for="order-client">
                            Cliente
                            <input id="client-search" class="client-search-input" type="search" placeholder="Buscar cliente" autocomplete="off" />
                            <select id="order-client" required>
                                <option value="">Seleccionar cliente</option>
                            </select>
                        </label>

                        <label class="field" for="payment-method">
                            Forma Pago
                            <select id="payment-method">
                                <option value="">Seleccionar forma de pago</option>
                            </select>
                        </label>

                        <label class="field" for="order-seller">
                            Vendedor
                            <select id="order-seller" required>
                                <option value="">Seleccionar vendedor</option>
                            </select>
                        </label>

                        <label class="field" for="order-delivery">
                            Fecha Entrega
                            <input id="order-delivery" required type="date" />
                        </label>

                        <label class="field" for="paid-amount">
                            Monto pagado
                            <input id="paid-amount" inputmode="numeric" placeholder="0" />
                        </label>

                        <label class="field" for="payment-status">
                            Estado de pago
                            <select id="payment-status">
                                <option value="">Seleccionar estado de pago</option>
                            </select>
                        </label>

                        <label class="field state-field" for="order-sale-status">
                            Estado
                            <select id="order-sale-status">
                                <option value="">Seleccionar estado</option>
                            </select>
                        </label>

                        <div class="field payment-proof-field compact-proof-field">
                            <label for="payment-proof">Comprobante de pago</label>
                            <div class="file-control payment-proof-control">
                                <input id="payment-proof" class="file-control-input" type="file" accept="image/*,.pdf" />
                                <label class="file-control-picker" for="payment-proof">Seleccionar archivo</label>
                                <span class="file-control-name" id="payment-proof-name">Sin comprobante adjunto</span>
                                <a class="file-control-download" id="payment-proof-download" href="#" download title="Descargar comprobante" aria-label="Descargar comprobante" hidden>
                                    <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
                                        <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 19h14" />
                                    </svg>
                                </a>
                            </div>
                        </div>

                        <label class="field notes-field" for="order-notes">
                            Observacion
                            <textarea id="order-notes" rows="2" placeholder="Notas del pedido"></textarea>
                        </label>
                    </div>
                </section>

                <section class="entry-section" aria-label="Detalle de productos y disenos">
                    <div class="section-title detail-title">
                        <span>Detalle de productos y disenos</span>
                        <button type="button" id="add-detail-button">+ Agregar detalle</button>
                    </div>

                    <div class="detail-table-wrap">
                        <div class="detail-list" id="detail-list"></div>
                    </div>
                </section>

                <footer class="entry-footer">
                    <div>
                        <span>Total estimado</span>
                        <strong id="estimated-total">Gs. 0</strong>
                    </div>
                    <button class="save-button" type="submit">Guardar</button>
                </footer>
            </form>
</section>

@section Scripts {
    <script>
        function localDateValue(date = new Date()) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, "0");
            const day = String(date.getDate()).padStart(2, "0");
            return `${year}-${month}-${day}`;
        }

        const today = localDateValue();
        let details = [];
        let formOptions = {
            clientes: [],
            formasPago: [],
            vendedores: [],
            estadosPago: [],
            estadosVenta: [],
            productos: [],
            maquinas: [],
            usuarioActualId: null
        };

        const form = document.getElementById("order-form");
        const title = document.getElementById("order-form-title");
        const detailList = document.getElementById("detail-list");
        const estimatedTotal = document.getElementById("estimated-total");
        const proofInput = document.getElementById("payment-proof");
        const proofName = document.getElementById("payment-proof-name");
        const proofDownload = document.getElementById("payment-proof-download");
        const clientSearchInput = document.getElementById("client-search");
        const clientSelect = document.getElementById("order-client");
        const paymentMethodSelect = document.getElementById("payment-method");
        const sellerSelect = document.getElementById("order-seller");
        const paymentStatusSelect = document.getElementById("payment-status");
        const saleStatusSelect = document.getElementById("order-sale-status");
        let loadedSaleStateId = "";
        let paymentProofFileName = "";
        let proofUrl = "";

        function numberValue(value) {
            return Number(String(value).replace(/\./g, "").replace(",", ".")) || 0;
        }

        function formatNumber(value) {
            const onlyNumbers = String(value).replace(/\D/g, "");
            return onlyNumbers ? Number(onlyNumbers).toLocaleString("es-PY") : "";
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;");
        }

        function selectOptions(items, selectedValue = "", placeholder = "Seleccionar") {
            const selected = String(selectedValue || "");
            return [
                `<option value="">${placeholder}</option>`,
                ...items.map(item => {
                    const value = String(item.value);
                    const isSelected = value === selected ? "selected" : "";
                    return `<option value="${escapeHtml(value)}" ${isSelected}>${escapeHtml(item.label)}</option>`;
                })
            ].join("");
        }

        function renderClientOptions(selectedValue = clientSelect.value) {
            const search = clientSearchInput.value.trim().toLowerCase();
            const selected = String(selectedValue || "");
            const clientes = formOptions.clientes.filter(client => {
                const value = String(client.id);
                const text = `${client.nombre || ""} ${client.documento || ""}`.toLowerCase();
                return !search || value === selected || text.includes(search);
            });

            clientSelect.innerHTML = selectOptions(
                clientes.map(client => ({
                    value: client.id,
                    label: client.documento ? `${client.nombre || `Cliente ${client.id}`} - ${client.documento}` : client.nombre || `Cliente ${client.id}`
                })),
                selected,
                "Seleccionar cliente"
            );
        }

        function getProduct(productId) {
            return formOptions.productos.find(product => String(product.id) === String(productId));
        }

        function getMachine(machineId) {
            return formOptions.maquinas.find(machine => String(machine.id) === String(machineId));
        }

        function findOptionId(items, expectedName) {
            const normalized = expectedName.toLowerCase();
            return items.find(item => String(item.nombre || "").toLowerCase().includes(normalized))?.id || "";
        }

        function paymentStatusIdByAmount(amount, total) {
            if (amount <= 0) {
                return findOptionId(formOptions.estadosPago, "pendiente");
            }

            if (total > 0 && amount >= total) {
                return findOptionId(formOptions.estadosPago, "pagado");
            }

            return findOptionId(formOptions.estadosPago, "parcial");
        }

        function stateById(id) {
            return formOptions.estadosVenta.find(item => String(item.id) === String(id));
        }

        function stateByFlow(flow) {
            return formOptions.estadosVenta.find(item => Number(item.numeroFlujo) === flow);
        }

        function initialSaleState() {
            return stateByFlow(1) || formOptions.estadosVenta[0];
        }

        function currentSaleState() {
            return stateById(loadedSaleStateId || saleStatusSelect.value) || initialSaleState();
        }

        function workflowStateOptions() {
            const current = currentSaleState();
            const flow = Number(current?.numeroFlujo);
            const options = [current];

            if (flow === 1) {
                options.push(stateByFlow(2));
            }

            if (flow === 2) {
                options.unshift(stateByFlow(1));
                options.push(stateByFlow(3));
            }

            if (flow === 3) {
                options.push(stateByFlow(4));
            }

            return options.filter((item, index, items) =>
                item?.id && items.findIndex(option => option?.id === item.id) === index);
        }

        function renderSaleStatusOptions(selectedValue = saleStatusSelect.value) {
            const allowedStates = orderId ? workflowStateOptions() : [initialSaleState()].filter(Boolean);
            saleStatusSelect.innerHTML = selectOptions(
                allowedStates.map(item => ({
                    value: item.id,
                    label: item.nombre || item.id
                })),
                selectedValue,
                "Seleccionar estado"
            );
            saleStatusSelect.disabled = !orderId;
        }

        function createDetail(seed = {}) {
            return {
                id: Date.now() + Math.random(),
                detailId: seed.id || seed.detailId || null,
                productId: seed.productId || "",
                machineId: seed.machineId || "",
                quantity: seed.quantity || "",
                unitPrice: seed.unitPrice || "",
                extraPrice: seed.extraPrice || "",
                designName: seed.designName || "",
                designUrl: seed.designUrl || ""
            };
        }

        function detailTotal(detail) {
            return numberValue(detail.quantity) * numberValue(detail.unitPrice) + numberValue(detail.extraPrice);
        }

        function updateEstimatedTotal() {
            const total = details.reduce((sum, detail) => sum + detailTotal(detail), 0);
            estimatedTotal.textContent = `Gs. ${total.toLocaleString("es-PY")}`;
            updatePaymentStatusFromAmount();
        }

        function updatePaymentStatusFromAmount() {
            const statusId = paymentStatusIdByAmount(
                numberValue(document.getElementById("paid-amount").value),
                details.reduce((sum, detail) => sum + detailTotal(detail), 0));

            if (statusId) {
                paymentStatusSelect.value = statusId;
            }
        }

        function setPaymentProof(name, url = "") {
            if (proofUrl) {
                URL.revokeObjectURL(proofUrl);
            }

            proofUrl = url;
            paymentProofFileName = name || "";
            proofName.textContent = name || "Sin comprobante adjunto";
            proofName.title = name || "";
            proofDownload.hidden = !name;
            proofDownload.href = url || "#";
            proofDownload.download = name || "";
        }

        function renderDetails() {
            detailList.innerHTML = details.map((detail, index) => `
                <article class="detail-row">
                    <div class="detail-row-header">
                        <span>Detalle #${index + 1}</span>
                        <button class="row-remove" type="button" onclick="removeDetail(${detail.id})">Quitar</button>
                    </div>

                    <div class="detail-grid">
                        <label class="detail-field product-field">
                            Producto
                            <select data-id="${detail.id}" data-field="productId">
                                ${selectOptions(
                                    formOptions.productos.map(product => ({
                                        value: product.id,
                                        label: product.nombre
                                    })),
                                    detail.productId,
                                    "Seleccionar producto"
                                )}
                            </select>
                        </label>

                        <label class="detail-field machine-field">
                            Maquina
                            <select data-id="${detail.id}" data-field="machineId">
                                ${selectOptions(
                                    formOptions.maquinas.map(machine => ({
                                        value: machine.id,
                                        label: machine.nombre
                                    })),
                                    detail.machineId,
                                    "Seleccionar maquina"
                                )}
                            </select>
                        </label>

                        <label class="detail-field quantity-field">
                            Cantidad
                            <input data-id="${detail.id}" data-field="quantity" inputmode="decimal" value="${detail.quantity}" />
                        </label>

                        <label class="detail-field price-field">
                            Precio unitario
                            <input data-id="${detail.id}" data-field="unitPrice" inputmode="numeric" value="${detail.unitPrice}" />
                        </label>

                        <label class="detail-field extra-field">
                            Precio extra
                            <input data-id="${detail.id}" data-field="extraPrice" inputmode="numeric" value="${detail.extraPrice}" />
                        </label>

                        <div class="detail-field design-field">
                            <label for="design-file-${detail.id}">Diseno PNG</label>
                            <div class="file-control">
                                <input id="design-file-${detail.id}" class="file-control-input" type="file" accept="image/png" data-id="${detail.id}" data-field="designName" />
                                <label class="file-control-picker" for="design-file-${detail.id}">Seleccionar archivo</label>
                                <span class="file-control-name">${detail.designName || "Sin diseno adjunto"}</span>
                                ${detail.designName ? `
                                    <a class="file-control-download" href="${detail.designUrl || "#"}" download="${detail.designName}" title="Descargar diseno" aria-label="Descargar diseno">
                                        <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
                                            <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 19h14" />
                                        </svg>
                                    </a>
                                ` : ""}
                            </div>
                        </div>

                        <div class="detail-total">
                            <span>Precio total</span>
                            <output data-total-id="${detail.id}">Gs. ${detailTotal(detail).toLocaleString("es-PY")}</output>
                        </div>
                    </div>
                </article>
            `).join("");

            detailList.querySelectorAll("[data-field]").forEach(input => {
                input.addEventListener("input", updateDetailFromInput);
                input.addEventListener("change", updateDetailFromInput);
            });

            updateEstimatedTotal();
        }

        function updateDetailFromInput(event) {
            const input = event.target;
            const id = Number(input.dataset.id);
            const field = input.dataset.field;
            const value = input.type === "file"
                ? input.files[0]?.name || ""
                : field === "unitPrice" || field === "extraPrice"
                    ? formatNumber(input.value)
                    : input.value;

            const selectedUrl = input.type === "file" && input.files[0]
                ? URL.createObjectURL(input.files[0])
                : "";

            details = details.map(detail => {
                if (detail.id !== id) {
                    return detail;
                }

                if (field === "designName") {
                    if (detail.designUrl) {
                        URL.revokeObjectURL(detail.designUrl);
                    }
                    return { ...detail, designName: value, designUrl: selectedUrl };
                }

                if (field === "productId") {
                    const product = getProduct(value);
                    return {
                        ...detail,
                        productId: value,
                        machineId: product?.maquinaId || detail.machineId,
                        unitPrice: product ? formatNumber(product.precioBase) : detail.unitPrice
                    };
                }

                return { ...detail, [field]: value };
            });

            if (event.type === "input" && ["quantity", "unitPrice", "extraPrice"].includes(field)) {
                const detail = details.find(item => item.id === id);
                const output = detailList.querySelector(`[data-total-id="${id}"]`);
                if (detail && output) {
                    output.textContent = `Gs. ${detailTotal(detail).toLocaleString("es-PY")}`;
                }
                updateEstimatedTotal();
                return;
            }

            renderDetails();
        }

        function removeDetail(id) {
            details = details.filter(detail => detail.id !== id);
            if (details.length === 0) {
                details = [createDetail()];
            }
            renderDetails();
        }

        function populateHeaderOptions() {
            renderClientOptions();

            paymentMethodSelect.innerHTML = selectOptions(
                formOptions.formasPago.map(item => ({
                    value: item.id,
                    label: item.nombre || item.id
                })),
                paymentMethodSelect.value,
                "Seleccionar forma de pago"
            );

            sellerSelect.innerHTML = selectOptions(
                formOptions.vendedores.map(item => ({
                    value: item.id,
                    label: item.persona || item.nombreUsuario || `Usuario ${item.id}`
                })),
                sellerSelect.value,
                "Seleccionar vendedor"
            );

            paymentStatusSelect.innerHTML = selectOptions(
                formOptions.estadosPago.map(item => ({
                    value: item.id,
                    label: item.nombre || item.id
                })),
                paymentStatusSelect.value,
                "Seleccionar estado de pago"
            );

            renderSaleStatusOptions();
        }

        async function loadFormOptions() {
            const response = await fetch("/api/pedidos/opciones");

            if (!response.ok) {
                showToast("No se pudieron cargar los datos del formulario desde el back.", "error");
                return false;
            }

            formOptions = await response.json();
            populateHeaderOptions();
            return true;
        }

        function applyDefaults() {
            paymentMethodSelect.value = findOptionId(formOptions.formasPago, "transferencia") || paymentMethodSelect.value;
            paymentStatusSelect.value = findOptionId(formOptions.estadosPago, "pendiente") || paymentStatusSelect.value;
            saleStatusSelect.value = initialSaleState()?.id || findOptionId(formOptions.estadosVenta, "cargado") || findOptionId(formOptions.estadosVenta, "pendiente") || saleStatusSelect.value;

            if (formOptions.usuarioActualId) {
                sellerSelect.value = String(formOptions.usuarioActualId);
            }

            loadedSaleStateId = saleStatusSelect.value;
            renderSaleStatusOptions(saleStatusSelect.value);
        }

        function loadOrder(order) {
            document.getElementById("order-id").value = order.id || "";
            document.getElementById("order-date").value = order.date || today;
            document.getElementById("order-status").value = order.status || "Cargado";
            document.getElementById("order-client").value = order.clientId || "";
            renderClientOptions(order.clientId || "");
            document.getElementById("payment-method").value = order.formaPagoId || "";
            document.getElementById("order-seller").value = order.vendedorId || "";
            document.getElementById("order-delivery").value = order.delivery || today;
            document.getElementById("paid-amount").value = formatNumber(order.paidAmount || "0");
            document.getElementById("payment-status").value = order.estadoPagadoId || "";
            document.getElementById("order-sale-status").value = order.estadoVentaId || "";
            loadedSaleStateId = order.estadoVentaId || saleStatusSelect.value || initialSaleState()?.id || "";
            renderSaleStatusOptions(order.estadoVentaId || loadedSaleStateId);
            document.getElementById("order-notes").value = order.notes || "";
            setPaymentProof(order.proofName || "");
            details = (order.details || [createDetail()]).map(detail => createDetail(detail));
            title.textContent = order.id ? `Editar pedido ${order.id}` : "Nuevo pedido";
            renderDetails();
        }

        document.getElementById("add-detail-button").addEventListener("click", function () {
            details = [...details, createDetail()];
            renderDetails();
        });

        proofInput.addEventListener("change", function () {
            const file = proofInput.files[0];
            setPaymentProof(file?.name || "", file ? URL.createObjectURL(file) : "");
        });

        clientSearchInput.addEventListener("input", function () {
            renderClientOptions();
        });

        document.getElementById("paid-amount").addEventListener("input", function (event) {
            event.target.value = formatNumber(event.target.value);
            updatePaymentStatusFromAmount();
        });

        async function saveOrder() {
            const previousStateId = saleStatusSelect.value;

            const payload = {
                clienteId: Number(clientSelect.value),
                formaPagoId: paymentMethodSelect.value,
                vendedorId: Number(sellerSelect.value),
                montoPagado: numberValue(document.getElementById("paid-amount").value),
                estadoPagadoId: paymentStatusSelect.value || null,
                fechaEntrega: document.getElementById("order-delivery").value || null,
                comprobantePago: paymentProofFileName || null,
                comprobantePagoNombre: paymentProofFileName || null,
                observacion: document.getElementById("order-notes").value || null,
                estadoVentaId: saleStatusSelect.value || null,
                detalles: details.map(detail => ({
                    id: detail.detailId,
                    productoId: Number(detail.productId),
                    tipoMaquinaId: Number(detail.machineId),
                    cantidad: numberValue(detail.quantity),
                    precioUnitario: numberValue(detail.unitPrice),
                    precioExtra: numberValue(detail.extraPrice),
                    archivoDisenio: detail.designName || null,
                    archivoDisenioNombre: detail.designName || null,
                    observacion: null,
                    estadoItem: null,
                    checkImpresion: false
                }))
            };

            if (!payload.clienteId || !payload.formaPagoId || !payload.vendedorId) {
                saleStatusSelect.value = previousStateId;
                showToast("Seleccione cliente, forma de pago y vendedor.", "error");
                return;
            }

            if (!payload.detalles.length || payload.detalles.some(detail => !detail.productoId || !detail.tipoMaquinaId || detail.cantidad <= 0)) {
                saleStatusSelect.value = previousStateId;
                showToast("Complete producto, maquina y cantidad en todos los detalles.", "error");
                return;
            }

            const saveUrl = orderId ? `/api/pedidos/${orderId}` : "/api/pedidos";
            const response = await fetch(saveUrl, {
                method: orderId ? "PUT" : "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                saleStatusSelect.value = previousStateId;
                let message = "No se pudo guardar la venta. Revise los datos obligatorios.";
                try {
                    const error = await response.json();
                    message = error.message || message;
                } catch {
                }

                showToast(message, "error");
                return;
            }

            showToast("Venta guardada correctamente.", "success");
            window.setTimeout(() => {
                window.location.href = "/pedidos";
            }, 700);
        }

        form.addEventListener("submit", async function (event) {
            event.preventDefault();
            await saveOrder();
        });

        const orderId = new URLSearchParams(window.location.search).get("id");
        async function loadInitialOrder() {
            const optionsLoaded = await loadFormOptions();
            if (!optionsLoaded) {
                return;
            }

            if (!orderId) {
                loadOrder({ date: today });
                applyDefaults();
                return;
            }

            const response = await fetch(`/api/pedidos/${orderId}`);
            if (!response.ok) {
                loadOrder({ date: today });
                return;
            }

            loadOrder(await response.json());
        }

        loadInitialOrder();
    </script>
}
