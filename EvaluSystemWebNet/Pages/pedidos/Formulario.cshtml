@page
@{
    var embedded = string.Equals(Request.Query["embedded"], "1", StringComparison.OrdinalIgnoreCase);
    Layout = embedded ? "_ModalLayout" : "_AppLayout";
    ViewData["Title"] = "Crear pedido";
    ViewData["ActiveMenu"] = "pedidos";
    ViewData["ShellClass"] = embedded ? "entry-shell embedded-entry-shell" : "entry-shell";
}

<section class="entry-main @(embedded ? "entry-main-embedded" : "")">
            <header class="entry-header">
                <div>
                    <p class="eyebrow">Carga de ventas impresiones</p>
                    <h1 id="order-form-title">Nuevo pedido</h1>
                    <p>Registra la venta y sus detalles para enviarla a produccion.</p>
                </div>
                <button class="back-list-button" type="button" onclick="closeEmbeddedForm()">Volver a la lista</button>
            </header>

            <form id="order-form" class="entry-form">
                <input type="hidden" id="order-id" />
                <input type="hidden" id="order-date" />
                <input type="hidden" id="order-status" />

                <div class="entry-top-row">
                    <section class="entry-section" aria-label="Carga de ventas impresiones">
                        <div class="section-title">Carga de ventas impresiones</div>

                        <div class="entry-fields">
                            <label class="field client-field" for="order-client">
                                Cliente
                                <select id="order-client" class="select2-hidden-select">
                                    <option value="">Seleccionar cliente</option>
                                </select>
                                <div id="client-select2" class="client-select2">
                                    <button id="client-select2-button" class="client-select2-button" type="button" aria-haspopup="listbox" aria-expanded="false">
                                        <span id="client-select2-label">Seleccionar cliente</span>
                                    </button>
                                    <div id="client-select2-dropdown" class="client-select2-dropdown" hidden>
                                        <input id="client-select2-search" class="client-select2-search" type="search" placeholder="Buscar cliente" autocomplete="off" />
                                        <div id="client-select2-options" class="client-select2-options" role="listbox"></div>
                                    </div>
                                </div>
                            </label>

                            <label class="field" for="payment-method">
                                Forma de pago
                                <select id="payment-method">
                                    <option value="">Seleccionar forma de pago</option>
                                </select>
                            </label>

                            <label class="field" for="order-seller">
                                Vendedor
                                <select id="order-seller" required>
                                    <option value="">Seleccionar vendedor</option>
                                </select>
                            </label>

                            <label class="field" for="order-delivery">
                                Fecha entrega
                                <input id="order-delivery" required type="date" />
                            </label>

                            <label class="field" for="paid-amount">
                                Monto pagado
                                <input id="paid-amount" inputmode="numeric" placeholder="0" />
                            </label>

                            <label class="field" for="payment-status">
                                Estado de pago
                                <select id="payment-status">
                                    <option value="">Seleccionar estado de pago</option>
                                </select>
                            </label>

                            <label class="field" for="delivery-method">
                                Forma de entrega
                                <select id="delivery-method">
                                    <option value="DELIVERY">Delivery</option>
                                    <option value="RETIRO_LOCAL">Retiro en local</option>
                                    <option value="MOTOBOLT">Motobolt</option>
                                    <option value="TRANSPORTADORA">Transportadora</option>
                                    <option value="OTRO">Otro</option>
                                </select>
                            </label>

                            <label class="field" for="delivery-user">
                                Usuario entrega pedido
                                <input id="delivery-user" readonly placeholder="Sin tomar" />
                            </label>

                            <label class="field state-field" for="order-sale-status">
                                Estado
                                <select id="order-sale-status">
                                    <option value="">Seleccionar estado</option>
                                </select>
                            </label>

                            <div class="field payment-proof-field compact-proof-field">
                                <label for="payment-proof">Comprobante de pago</label>
                                <div class="file-control payment-proof-control">
                                    <input id="payment-proof" class="file-control-input" type="file" accept="image/*,.pdf" />
                                    <label class="file-control-picker" for="payment-proof">Seleccionar archivo</label>
                                    <span class="file-control-name" id="payment-proof-name">Sin comprobante adjunto</span>
                                    <a class="file-control-download" id="payment-proof-download" href="#" download title="Descargar comprobante" aria-label="Descargar comprobante" hidden>
                                        <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
                                            <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 19h14" />
                                        </svg>
                                    </a>
                                </div>
                            </div>

                            <label class="field notes-field" for="order-notes">
                                Observacion
                                <textarea id="order-notes" rows="2" placeholder="Notas del pedido"></textarea>
                            </label>
                        </div>
                    </section>

                    <section class="entry-section order-actions-section" aria-label="Acciones del pedido">
                        <div class="section-title">Acciones del pedido</div>

                        <div class="order-state-actions" aria-label="Acciones del pedido">
                            <button id="state-back-action" class="order-action-button order-action-back" type="button">Devolver</button>
                            <button id="state-save-action" class="order-action-button order-action-save" type="button">Guardar</button>
                            <button id="state-next-action" class="order-action-button order-action-next" type="button">Siguiente</button>
                            <button id="state-delete-action" class="order-action-button order-action-delete" type="button">Eliminar</button>
                        </div>
                    </section>
                </div>

                <section class="entry-section" aria-label="Detalle de productos y disenos">
                    <div class="section-title detail-title">
                        <span>Detalle de productos y disenos</span>
                        <button type="button" id="add-detail-button">+ Agregar detalle</button>
                    </div>

                    <div class="detail-table-wrap">
                        <div class="detail-list" id="detail-list"></div>
                    </div>
                </section>

                <footer class="entry-footer">
                    <div>
                        <span>Total estimado</span>
                        <strong id="estimated-total">Gs. 0</strong>
                    </div>
                </footer>
            </form>
</section>

@section Scripts {
    <script>
        const isEmbedded = @(embedded ? "true" : "false");

        function closeEmbeddedForm() {
            if (isEmbedded && window.parent) {
                window.parent.postMessage({ type: "order-modal-close" }, window.location.origin);
                return;
            }

            window.location.href = "/pedidos";
        }

        function notifyEmbeddedSaved() {
            if (isEmbedded && window.parent) {
                window.parent.postMessage({ type: "order-modal-saved" }, window.location.origin);
                return true;
            }

            return false;
        }

        function localDateValue(date = new Date()) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, "0");
            const day = String(date.getDate()).padStart(2, "0");
            return `${year}-${month}-${day}`;
        }

        const today = localDateValue();
        let details = [];
        let formOptions = {
            clientes: [],
            formasPago: [],
            vendedores: [],
            estadosPago: [],
            estadosVenta: [],
            productos: [],
            maquinas: [],
            usuarioActualId: null,
            puedeVerTodosPedidos: false
        };

        const form = document.getElementById("order-form");
        const title = document.getElementById("order-form-title");
        const detailList = document.getElementById("detail-list");
        const estimatedTotal = document.getElementById("estimated-total");
        const proofInput = document.getElementById("payment-proof");
        const proofName = document.getElementById("payment-proof-name");
        const proofDownload = document.getElementById("payment-proof-download");
        const clientSelect = document.getElementById("order-client");
        const clientSelect2 = document.getElementById("client-select2");
        const clientSelect2Button = document.getElementById("client-select2-button");
        const clientSelect2Label = document.getElementById("client-select2-label");
        const clientSelect2Dropdown = document.getElementById("client-select2-dropdown");
        const clientSelect2Search = document.getElementById("client-select2-search");
        const clientSelect2Options = document.getElementById("client-select2-options");
        const paymentMethodSelect = document.getElementById("payment-method");
        const sellerSelect = document.getElementById("order-seller");
        const deliveryMethodSelect = document.getElementById("delivery-method");
        const deliveryUserInput = document.getElementById("delivery-user");
        const paymentStatusSelect = document.getElementById("payment-status");
        const saleStatusSelect = document.getElementById("order-sale-status");
        const stateBackAction = document.getElementById("state-back-action");
        const stateSaveAction = document.getElementById("state-save-action");
        const stateNextAction = document.getElementById("state-next-action");
        const stateDeleteAction = document.getElementById("state-delete-action");
        let loadedSaleStateId = "";
        let paymentProofPath = "";
        let paymentProofFileName = "";
        let proofUrl = "";

        function numberValue(value) {
            return Number(String(value).replace(/\./g, "").replace(",", ".")) || 0;
        }

        function formatNumber(value) {
            const onlyNumbers = String(value).replace(/\D/g, "");
            return onlyNumbers ? Number(onlyNumbers).toLocaleString("es-PY") : "";
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;");
        }

        function shortPersonName(value) {
            const parts = String(value || "").trim().split(/\s+/).filter(Boolean);
            return parts.length > 1 ? `${parts[0]} ${parts[parts.length - 1]}` : parts[0] || "";
        }

        function sellerShortName(value) {
            const parts = String(value || "").trim().split(/\s+/).filter(Boolean);
            if (parts.length >= 3) {
                return `${parts[0]} ${parts[2]}`;
            }

            return parts.length > 1 ? `${parts[0]} ${parts[1]}` : parts[0] || "";
        }

        function selectOptions(items, selectedValue = "", placeholder = "Seleccionar") {
            const selected = String(selectedValue || "");
            return [
                `<option value="">${placeholder}</option>`,
                ...items.map(item => {
                    const value = String(item.value);
                    const isSelected = value === selected ? "selected" : "";
                    return `<option value="${escapeHtml(value)}" ${isSelected}>${escapeHtml(item.label)}</option>`;
                })
            ].join("");
        }

        function clientOptionLabel(client) {
            return client.documento
                ? `${client.nombre || `Cliente ${client.id}`} - ${client.documento}`
                : client.nombre || `Cliente ${client.id}`;
        }

        function renderClientOptions(selectedValue = clientSelect.value) {
            const selected = String(selectedValue || "");
            clientSelect.innerHTML = selectOptions(
                formOptions.clientes.map(client => ({
                    value: client.id,
                    label: clientOptionLabel(client)
                })),
                selected,
                "Seleccionar cliente"
            );
            updateClientSelect2Label();
            renderClientSelect2Options();
        }

        function updateClientSelect2Label() {
            const selectedClient = formOptions.clientes.find(client => String(client.id) === String(clientSelect.value));
            clientSelect2Label.textContent = selectedClient ? clientOptionLabel(selectedClient) : "Seleccionar cliente";
        }

        function applyDeliveryMethodFromClient() {
            const selectedClient = formOptions.clientes.find(client => String(client.id) === String(clientSelect.value));
            const hasCarrierShipping = Boolean(selectedClient?.datosEnvio || selectedClient?.transportadoraId || selectedClient?.transportadora);
            deliveryMethodSelect.value = hasCarrierShipping ? "TRANSPORTADORA" : "DELIVERY";
        }

        function renderClientSelect2Options() {
            const search = clientSelect2Search.value.trim().toLowerCase();
            const selected = String(clientSelect.value || "");
            const clientes = formOptions.clientes.filter(client => {
                const text = `${client.nombre || ""} ${client.documento || ""}`.toLowerCase();
                return !search || text.includes(search);
            });

            clientSelect2Options.innerHTML = clientes.length
                ? clientes.map(client => {
                    const value = String(client.id);
                    const isSelected = value === selected ? " is-selected" : "";
                    return `<button class="client-select2-option${isSelected}" type="button" role="option" data-value="${escapeHtml(value)}">${escapeHtml(clientOptionLabel(client))}</button>`;
                }).join("")
                : `<div class="client-select2-empty">Sin resultados</div>`;
        }

        function setClientSelect2Open(isOpen) {
            clientSelect2Dropdown.hidden = !isOpen;
            clientSelect2Button.setAttribute("aria-expanded", String(isOpen));

            if (isOpen) {
                clientSelect2Search.value = "";
                clientSelect2Search.focus();
                renderClientSelect2Options();
            }
        }

        function getProduct(productId) {
            return formOptions.productos.find(product => String(product.id) === String(productId));
        }

        function getMachine(machineId) {
            return formOptions.maquinas.find(machine => String(machine.id) === String(machineId));
        }

        function findOptionId(items, expectedName) {
            const normalized = expectedName.toLowerCase();
            return items.find(item => String(item.nombre || "").toLowerCase().includes(normalized))?.id || "";
        }

        function paymentStatusIdByAmount(amount, total) {
            if (amount <= 0) {
                return findOptionId(formOptions.estadosPago, "pendiente");
            }

            if (total > 0 && amount >= total) {
                return findOptionId(formOptions.estadosPago, "pagado");
            }

            return findOptionId(formOptions.estadosPago, "parcial");
        }

        function stateById(id) {
            return formOptions.estadosVenta.find(item => String(item.id) === String(id));
        }

        function stateByFlow(flow) {
            return formOptions.estadosVenta.find(item => Number(item.numeroFlujo) === flow);
        }

        function initialSaleState() {
            return stateByFlow(1) || formOptions.estadosVenta[0];
        }

        function currentSaleState() {
            return stateById(loadedSaleStateId || saleStatusSelect.value) || initialSaleState();
        }

        function previousSaleState() {
            return null;
        }

        function nextSaleState() {
            const flow = Number(currentSaleState()?.numeroFlujo);

            if (flow === 1) {
                return stateByFlow(2);
            }

            return null;
        }

        function deleteSaleState() {
            return stateByFlow(5);
        }

        function ensureSaleStatusOption(state) {
            if (!state?.id || Array.from(saleStatusSelect.options).some(option => option.value === String(state.id))) {
                return;
            }

            const option = document.createElement("option");
            option.value = state.id;
            option.textContent = state.nombre || state.id;
            saleStatusSelect.appendChild(option);
        }

        function setSaleStatusValue(state) {
            if (!state?.id) {
                return false;
            }

            ensureSaleStatusOption(state);
            saleStatusSelect.value = state.id;
            updateStateActionButtons();
            return true;
        }

        function isMovingFromCargaToImpresion(destinationStateId = saleStatusSelect.value) {
            const current = currentSaleState();
            const destination = stateById(destinationStateId);
            return Number(current?.numeroFlujo) === 1 && Number(destination?.numeroFlujo) === 2;
        }

        function canDeleteCurrentOrder() {
            return Number(currentSaleState()?.numeroFlujo) === 1;
        }

        function isPaidStatusSelected(statusId = paymentStatusSelect.value) {
            return String(statusId || "") === String(findOptionId(formOptions.estadosPago, "pagado") || "");
        }

        function workflowStateOptions() {
            const current = currentSaleState();
            const flow = Number(current?.numeroFlujo);
            const options = [current];

            if (flow === 1) {
                options.push(stateByFlow(2));
            }

            return options.filter((item, index, items) =>
                item?.id && items.findIndex(option => option?.id === item.id) === index);
        }

        function renderSaleStatusOptions(selectedValue = saleStatusSelect.value) {
            const allowedStates = orderId ? workflowStateOptions() : [initialSaleState()].filter(Boolean);
            saleStatusSelect.innerHTML = selectOptions(
                allowedStates.map(item => ({
                    value: item.id,
                    label: item.nombre || item.id
                })),
                selectedValue,
                "Seleccionar estado"
            );
            saleStatusSelect.disabled = true;
            updateStateActionButtons();
        }

        function updateStateActionButtons() {
            const previous = previousSaleState();
            const next = nextSaleState();
            const hasOrder = Boolean(orderId);

            stateBackAction.disabled = !hasOrder || !previous;
            stateNextAction.disabled = !hasOrder || !next;
            stateDeleteAction.disabled = !hasOrder || !canDeleteCurrentOrder();
            stateSaveAction.disabled = false;

            stateBackAction.textContent = previous ? `Devolver a ${previous.nombre || previous.id}` : "Devolver";
            stateNextAction.textContent = next ? `Siguiente a ${next.nombre || next.id}` : "Siguiente";
            stateDeleteAction.title = stateDeleteAction.disabled && hasOrder
                ? "Solo se puede eliminar un pedido en estado Carga."
                : "";
        }

        function createDetail(seed = {}) {
            return {
                id: Date.now() + Math.random(),
                detailId: seed.id || seed.detailId || null,
                productId: seed.productId || "",
                machineId: seed.machineId || "",
                quantity: seed.quantity || "",
                unitPrice: seed.unitPrice || "",
                extraPrice: seed.extraPrice || "",
                designPath: seed.designPath || "",
                designName: seed.designName || "",
                designUrl: seed.designUrl || "",
                designFile: seed.designFile || null
            };
        }

        function detailTotal(detail) {
            return numberValue(detail.quantity) * numberValue(detail.unitPrice) + numberValue(detail.extraPrice);
        }

        function updateEstimatedTotal() {
            const total = details.reduce((sum, detail) => sum + detailTotal(detail), 0);
            estimatedTotal.textContent = `Gs. ${total.toLocaleString("es-PY")}`;
            updatePaymentStatusFromAmount();
        }

        function updatePaymentStatusFromAmount() {
            const statusId = paymentStatusIdByAmount(
                numberValue(document.getElementById("paid-amount").value),
                details.reduce((sum, detail) => sum + detailTotal(detail), 0));

            if (statusId) {
                paymentStatusSelect.value = statusId;
            }
        }

        function downloadUrl(path, name) {
            if (!path) {
                return "";
            }

            let url = `/api/archivos/download?ruta=${encodeURIComponent(path)}`;
            if (name) {
                url += `&nombreDescarga=${encodeURIComponent(name)}`;
            }

            return url;
        }

        function setPaymentProof(name, url = "", path = "") {
            if (proofUrl && proofUrl.startsWith("blob:")) {
                URL.revokeObjectURL(proofUrl);
            }

            proofUrl = url;
            paymentProofPath = path || "";
            paymentProofFileName = name || "";
            proofName.textContent = name || "Sin comprobante adjunto";
            proofName.title = name || "";
            proofDownload.hidden = !url;
            proofDownload.href = url || "#";
            proofDownload.download = name || "";
        }

        function renderDetails() {
            detailList.innerHTML = details.map((detail, index) => `
                <article class="detail-row">
                    <div class="detail-row-header">
                        <span>Detalle #${index + 1}</span>
                        <button class="row-remove" type="button" onclick="removeDetail(${detail.id})">Quitar</button>
                    </div>

                    <div class="detail-grid">
                        <label class="detail-field product-field">
                            Producto
                            <select data-id="${detail.id}" data-field="productId">
                                ${selectOptions(
                                    formOptions.productos.map(product => ({
                                        value: product.id,
                                        label: product.nombre
                                    })),
                                    detail.productId,
                                    "Seleccionar producto"
                                )}
                            </select>
                        </label>

                        <label class="detail-field machine-field">
                            Maquina
                            <select data-id="${detail.id}" data-field="machineId">
                                ${selectOptions(
                                    formOptions.maquinas.map(machine => ({
                                        value: machine.id,
                                        label: machine.nombre
                                    })),
                                    detail.machineId,
                                    "Seleccionar maquina"
                                )}
                            </select>
                        </label>

                        <label class="detail-field quantity-field">
                            Cantidad
                            <input data-id="${detail.id}" data-field="quantity" inputmode="decimal" value="${detail.quantity}" />
                        </label>

                        <label class="detail-field price-field">
                            Precio unitario
                            <input data-id="${detail.id}" data-field="unitPrice" inputmode="numeric" value="${detail.unitPrice}" />
                        </label>

                        <label class="detail-field extra-field">
                            Precio extra
                            <input data-id="${detail.id}" data-field="extraPrice" inputmode="numeric" value="${detail.extraPrice}" />
                        </label>

                        <div class="detail-field design-field">
                            <label for="design-file-${detail.id}">Diseno PNG</label>
                            <div class="file-control">
                                <input id="design-file-${detail.id}" class="file-control-input" type="file" accept="image/png" data-id="${detail.id}" data-field="designName" />
                                <label class="file-control-picker" for="design-file-${detail.id}">Seleccionar archivo</label>
                                <span class="file-control-name">${detail.designName || "Sin diseno adjunto"}</span>
                                ${detail.designName ? `
                                    <a class="file-control-download" href="${detail.designUrl || downloadUrl(detail.designPath, detail.designName) || "#"}" download="${detail.designName}" title="Descargar diseno" aria-label="Descargar diseno">
                                        <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
                                            <path d="M12 3v11m0 0 4-4m-4 4-4-4M5 19h14" />
                                        </svg>
                                    </a>
                                ` : ""}
                            </div>
                        </div>

                        <div class="detail-total">
                            <span>Precio total</span>
                            <output data-total-id="${detail.id}">Gs. ${detailTotal(detail).toLocaleString("es-PY")}</output>
                        </div>
                    </div>
                </article>
            `).join("");

            detailList.querySelectorAll("[data-field]").forEach(input => {
                input.addEventListener("input", updateDetailFromInput);
                input.addEventListener("change", updateDetailFromInput);
            });

            updateEstimatedTotal();
        }

        async function updateDetailFromInput(event) {
            const input = event.target;
            const id = Number(input.dataset.id);
            const field = input.dataset.field;
            const selectedFile = input.type === "file" ? input.files[0] : null;
            const value = input.type === "file"
                ? selectedFile?.name || ""
                : field === "unitPrice" || field === "extraPrice"
                    ? formatNumber(input.value)
                    : input.value;

            const selectedUrl = selectedFile
                ? URL.createObjectURL(selectedFile)
                : "";
            details = details.map(detail => {
                if (detail.id !== id) {
                    return detail;
                }

                if (field === "designName") {
                    if (detail.designUrl && detail.designUrl.startsWith("blob:")) {
                        URL.revokeObjectURL(detail.designUrl);
                    }
                    return { ...detail, designName: value, designUrl: selectedUrl, designPath: "", designFile: selectedFile };
                }

                if (field === "productId") {
                    const product = getProduct(value);
                    return {
                        ...detail,
                        productId: value,
                        machineId: product?.maquinaId || detail.machineId,
                        unitPrice: product ? formatNumber(product.precioBase) : detail.unitPrice
                    };
                }

                return { ...detail, [field]: value };
            });

            if (event.type === "input" && ["quantity", "unitPrice", "extraPrice"].includes(field)) {
                const detail = details.find(item => item.id === id);
                const output = detailList.querySelector(`[data-total-id="${id}"]`);
                if (detail && output) {
                    output.textContent = `Gs. ${detailTotal(detail).toLocaleString("es-PY")}`;
                }
                updateEstimatedTotal();
                return;
            }

            renderDetails();
        }

        function removeDetail(id) {
            details = details.filter(detail => detail.id !== id);
            if (details.length === 0) {
                details = [createDetail()];
            }
            renderDetails();
        }

        function populateHeaderOptions() {
            renderClientOptions();

            paymentMethodSelect.innerHTML = selectOptions(
                formOptions.formasPago.map(item => ({
                    value: item.id,
                    label: item.nombre || item.id
                })),
                paymentMethodSelect.value,
                "Seleccionar forma de pago"
            );

            sellerSelect.innerHTML = selectOptions(
                formOptions.vendedores.map(item => ({
                    value: item.id,
                    label: sellerShortName(item.persona) || item.nombreUsuario || `Usuario ${item.id}`
                })),
                sellerSelect.value,
                "Seleccionar vendedor"
            );
            sellerSelect.disabled = !formOptions.puedeVerTodosPedidos;
            sellerSelect.classList.toggle("is-locked", !formOptions.puedeVerTodosPedidos);

            if (!formOptions.puedeVerTodosPedidos && formOptions.usuarioActualId) {
                sellerSelect.value = String(formOptions.usuarioActualId);
            }

            paymentStatusSelect.innerHTML = selectOptions(
                formOptions.estadosPago.map(item => ({
                    value: item.id,
                    label: item.nombre || item.id
                })),
                paymentStatusSelect.value,
                "Seleccionar estado de pago"
            );

            renderSaleStatusOptions();
        }

        async function loadFormOptions() {
            return await withAppLoading("Cargando datos...", async function () {
                const response = await fetch("/api/pedidos/opciones");

                if (!response.ok) {
                    showToast("No se pudieron cargar los datos del formulario desde el back.", "error");
                    return false;
                }

                formOptions = await response.json();
                populateHeaderOptions();
                return true;
            });
        }

        function applyDefaults() {
            paymentMethodSelect.value = findOptionId(formOptions.formasPago, "transferencia") || paymentMethodSelect.value;
            paymentStatusSelect.value = findOptionId(formOptions.estadosPago, "pendiente") || paymentStatusSelect.value;
            deliveryMethodSelect.value = "DELIVERY";
            saleStatusSelect.value = initialSaleState()?.id || findOptionId(formOptions.estadosVenta, "cargado") || findOptionId(formOptions.estadosVenta, "pendiente") || saleStatusSelect.value;

            if (formOptions.usuarioActualId) {
                sellerSelect.value = String(formOptions.usuarioActualId);
            }

            sellerSelect.disabled = !formOptions.puedeVerTodosPedidos;

            loadedSaleStateId = saleStatusSelect.value;
            renderSaleStatusOptions(saleStatusSelect.value);
        }

        function loadOrder(order) {
            document.getElementById("order-id").value = order.id || "";
            document.getElementById("order-date").value = order.date || today;
            document.getElementById("order-status").value = order.status || "Cargado";
            document.getElementById("order-client").value = order.clientId || "";
            renderClientOptions(order.clientId || "");
            document.getElementById("payment-method").value = order.formaPagoId || "";
            document.getElementById("order-seller").value = formOptions.puedeVerTodosPedidos
                ? order.vendedorId || ""
                : formOptions.usuarioActualId || "";
            document.getElementById("order-delivery").value = order.delivery || today;
            deliveryMethodSelect.value = order.deliveryMethodId || "DELIVERY";
            deliveryUserInput.value = order.deliveryUser ? shortPersonName(order.deliveryUser) : "Sin tomar";
            document.getElementById("paid-amount").value = formatNumber(order.paidAmount || "0");
            document.getElementById("payment-status").value = order.estadoPagadoId || "";
            document.getElementById("order-sale-status").value = order.estadoVentaId || "";
            loadedSaleStateId = order.estadoVentaId || saleStatusSelect.value || initialSaleState()?.id || "";
            renderSaleStatusOptions(order.estadoVentaId || loadedSaleStateId);
            document.getElementById("order-notes").value = order.notes || "";
            setPaymentProof(order.proofName || "", downloadUrl(order.proofPath, order.proofName), order.proofPath || "");
            details = (order.details || [createDetail()]).map(detail => createDetail(detail));
            title.textContent = order.id ? `Editar pedido ${order.id}` : "Nuevo pedido";
            renderDetails();
        }

        document.getElementById("add-detail-button").addEventListener("click", function () {
            details = [...details, createDetail()];
            renderDetails();
        });

        proofInput.addEventListener("change", function () {
            const file = proofInput.files[0];
            setPaymentProof(file?.name || "", file ? URL.createObjectURL(file) : "", "");
        });

        clientSelect2Button.addEventListener("click", function () {
            setClientSelect2Open(clientSelect2Dropdown.hidden);
        });

        clientSelect2Search.addEventListener("input", renderClientSelect2Options);
        clientSelect.addEventListener("change", function () {
            updateClientSelect2Label();
            applyDeliveryMethodFromClient();
        });

        clientSelect2Options.addEventListener("click", function (event) {
            const option = event.target.closest("[data-value]");
            if (!option) {
                return;
            }

            clientSelect.value = option.dataset.value;
            updateClientSelect2Label();
            applyDeliveryMethodFromClient();
            renderClientSelect2Options();
            setClientSelect2Open(false);
        });

        document.addEventListener("click", function (event) {
            if (!clientSelect2.contains(event.target)) {
                setClientSelect2Open(false);
            }
        });

        document.getElementById("paid-amount").addEventListener("input", function (event) {
            event.target.value = formatNumber(event.target.value);
            updatePaymentStatusFromAmount();
        });

        async function uploadFile(file, folder) {
            const formData = new FormData();
            formData.append("archivo", file);
            formData.append("carpeta", folder);

            const response = await fetch("/api/archivos/upload", {
                method: "POST",
                body: formData
            });

            if (!response.ok) {
                const error = await response.json().catch(() => null);
                throw new Error(error?.message || "No se pudo subir el archivo al servidor.");
            }

            return await response.json();
        }

        async function prepareFilesForSave(payload) {
            const proofFile = proofInput.files[0];
            if (proofFile) {
                const uploaded = await uploadFile(proofFile, "comprobantes-pago");
                paymentProofPath = uploaded.ruta || "";
                paymentProofFileName = uploaded.nombreDescarga || uploaded.nombreOriginal || proofFile.name;
                payload.comprobantePago = paymentProofPath || null;
                payload.comprobantePagoNombre = paymentProofFileName || null;
            }

            for (let index = 0; index < details.length; index++) {
                const detail = details[index];
                if (!detail.designFile) {
                    payload.detalles[index].archivoDisenio = detail.designPath || null;
                    payload.detalles[index].archivoDisenioNombre = detail.designName || null;
                    continue;
                }

                const uploaded = await uploadFile(detail.designFile, "disenos-pedidos");
                detail.designPath = uploaded.ruta || "";
                detail.designName = uploaded.nombreDescarga || uploaded.nombreOriginal || detail.designFile.name;
                detail.designFile = null;
                payload.detalles[index].archivoDisenio = detail.designPath || null;
                payload.detalles[index].archivoDisenioNombre = detail.designName || null;
            }
        }

        async function saveOrder(targetStateId = null) {
            const previousStateId = saleStatusSelect.value;
            const isStateChange = Boolean(targetStateId);
            const currentStateId = loadedSaleStateId || saleStatusSelect.value || initialSaleState()?.id || "";

            if (targetStateId) {
                const targetState = stateById(targetStateId);
                ensureSaleStatusOption(targetState);
                saleStatusSelect.value = targetStateId;
            } else if (currentStateId) {
                ensureSaleStatusOption(stateById(currentStateId));
                saleStatusSelect.value = currentStateId;
            }

            const payload = {
                clienteId: Number(clientSelect.value),
                formaPagoId: paymentMethodSelect.value,
                vendedorId: Number(sellerSelect.value),
                montoPagado: numberValue(document.getElementById("paid-amount").value),
                estadoPagadoId: paymentStatusSelect.value || null,
                fechaEntrega: document.getElementById("order-delivery").value || null,
                comprobantePago: paymentProofPath || null,
                comprobantePagoNombre: paymentProofFileName || null,
                observacion: document.getElementById("order-notes").value || null,
                metodoEntrega: deliveryMethodSelect.value || "DELIVERY",
                estadoVentaId: isStateChange ? targetStateId : currentStateId,
                detalles: details.map(detail => ({
                    id: detail.detailId,
                    productoId: Number(detail.productId),
                    tipoMaquinaId: Number(detail.machineId),
                    cantidad: numberValue(detail.quantity),
                    precioUnitario: numberValue(detail.unitPrice),
                    precioExtra: numberValue(detail.extraPrice),
                    archivoDisenio: detail.designPath || null,
                    archivoDisenioNombre: detail.designName || null,
                    observacion: null,
                    estadoItem: null,
                    checkImpresion: false
                }))
            };

            if (!payload.clienteId || !payload.formaPagoId || !payload.vendedorId) {
                saleStatusSelect.value = previousStateId;
                showToast("Seleccione cliente, forma de pago y vendedor.", "error");
                return;
            }

            if (!payload.detalles.length || payload.detalles.some(detail => !detail.productoId || !detail.tipoMaquinaId || detail.cantidad <= 0)) {
                saleStatusSelect.value = previousStateId;
                showToast("Complete producto, maquina y cantidad en todos los detalles.", "error");
                return;
            }

            if (isMovingFromCargaToImpresion(payload.estadoVentaId) && details.some(detail => !detail.designName)) {
                saleStatusSelect.value = previousStateId;
                showToast("Para enviar a impresion debe adjuntar el diseno en todos los detalles.", "error");
                return;
            }

            if (isPaidStatusSelected(payload.estadoPagadoId) && !paymentProofFileName) {
                saleStatusSelect.value = previousStateId;
                showToast("Para marcar como pagado debe adjuntar el comprobante de pago.", "error");
                return;
            }

            let response;
            try {
                response = await withAppLoading("Guardando pedido...", async function () {
                    await prepareFilesForSave(payload);
                    const saveUrl = orderId ? `/api/pedidos/${orderId}` : "/api/pedidos";
                    return await fetch(saveUrl, {
                        method: orderId ? "PUT" : "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify(payload)
                    });
                });
            } catch (error) {
                saleStatusSelect.value = previousStateId;
                showToast(error?.message || "No se pudo subir el archivo al servidor.", "error");
                return;
            }

            if (!response.ok) {
                saleStatusSelect.value = previousStateId;
                let message = "No se pudo guardar la venta. Revise los datos obligatorios.";
                try {
                    const error = await response.json();
                    message = error.message || message;
                } catch {
                }

                showToast(message, "error");
                return;
            }

            showToast("Venta guardada correctamente.", "success");
            window.setTimeout(() => {
                if (!notifyEmbeddedSaved()) {
                    window.location.href = "/pedidos";
                }
            }, 700);
        }

        async function saveWithTargetState(state) {
            if (!setSaleStatusValue(state)) {
                showToast("No se encontro el estado solicitado.", "error");
                return;
            }

            await saveOrder(state.id);
        }

        stateBackAction.addEventListener("click", async function () {
            await saveWithTargetState(previousSaleState());
        });

        stateSaveAction.addEventListener("click", async function () {
            await saveOrder();
        });

        stateNextAction.addEventListener("click", async function () {
            await saveWithTargetState(nextSaleState());
        });

        stateDeleteAction.addEventListener("click", async function () {
            if (!canDeleteCurrentOrder()) {
                showToast("Solo se puede eliminar un pedido cuando esta en estado Carga.", "error");
                return;
            }

            const deleteComment = document.getElementById("order-notes").value.trim();
            if (!deleteComment) {
                showToast("Agregue un comentario en Observacion antes de eliminar el pedido.", "error");
                document.getElementById("order-notes").focus();
                return;
            }

            const confirmed = await showConfirmDialog({
                title: "Eliminar pedido",
                message: `Seguro que desea eliminar el pedido ${orderId}? Esta accion no se puede deshacer.`,
                confirmText: "Eliminar pedido",
                cancelText: "Conservar"
            });

            if (!confirmed) {
                return;
            }

            const response = await withAppLoading("Eliminando pedido...", async function () {
                return await fetch(`/api/pedidos/${orderId}`, {
                    method: "DELETE",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        observacion: deleteComment
                    })
                });
            });

            if (!response.ok) {
                showToast("No se pudo eliminar el pedido.", "error");
                return;
            }

            showToast("Pedido eliminado correctamente.", "success");
            window.setTimeout(() => {
                if (!notifyEmbeddedSaved()) {
                    window.location.href = "/pedidos";
                }
            }, 700);
        });

        form.addEventListener("submit", async function (event) {
            event.preventDefault();
            await saveOrder();
        });

        const orderId = new URLSearchParams(window.location.search).get("id");
        async function loadInitialOrder() {
            const optionsLoaded = await loadFormOptions();
            if (!optionsLoaded) {
                return;
            }

            if (!orderId) {
                loadOrder({ date: today });
                applyDefaults();
                return;
            }

            const response = await withAppLoading("Cargando pedido...", async function () {
                return await fetch(`/api/pedidos/${orderId}`);
            });
            if (!response.ok) {
                loadOrder({ date: today });
                return;
            }

            loadOrder(await response.json());
        }

        loadInitialOrder();
    </script>
}
