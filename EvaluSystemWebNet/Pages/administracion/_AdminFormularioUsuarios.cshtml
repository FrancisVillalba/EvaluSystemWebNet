<section class="admin-panel" data-module-panel="usuarios">
    <div class="admin-panel-header">
        <div>
            <h2>Usuarios</h2>
            <p>Crea y mantiene los usuarios del sistema.</p>
        </div>
        <button class="admin-primary new-record-button" type="button">
            <svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 5v14" /><path d="M5 12h14" /></svg>
            <span>Nuevo</span>
        </button>
    </div>
    <form class="admin-form" data-admin-form>
        <label class="admin-field">Usuario <input data-field="nombreUsuario" type="text" required /></label> 
        <label class="admin-field">Contrasena<input data-field="pass" type="password" /><span>Dejar vacio para no cambiar</span></label>
        <label class="admin-field">Persona<select data-field="personaId" data-source="personas"><option value="">Seleccionar</option></select></label>
        <fieldset class="admin-field admin-multi-field" data-multiselect-field="perfilIds">
            <legend>Perfiles</legend>
            <div class="admin-multiselect" data-multiselect="perfilIds">
                <button class="admin-multiselect-button" type="button" data-multiselect-toggle aria-expanded="false"><span data-multiselect-summary>Seleccionar</span></button>
                <div class="admin-multiselect-values" data-multiselect-values></div>
                <div class="admin-multiselect-dropdown" data-multiselect-dropdown hidden>
                    <input class="admin-multiselect-search" type="search" placeholder="Buscar..." data-multiselect-search autocomplete="off">
                    <div class="admin-multiselect-options" data-multiselect-options></div>
                </div>
            </div>
        </fieldset>
        <label class="admin-check admin-check-field"><input data-field="estado" type="checkbox" checked />Activo</label>
        <div class="admin-form-actions">
            <div class="admin-form-buttons"><button class="admin-secondary cancel-record-button" type="button">Cancelar</button><button class="admin-primary save-record-button" type="button"><span data-save-label>Crear</span></button></div>
        </div>
    </form>
    <partial name="_AdminFormularioTabla" model='@(new[] { "Usuario", "Persona", "Perfiles", "Estado" })' />
</section>

<script>
    window.adminModuleDefinitions = window.adminModuleDefinitions || {};
    window.adminModuleDefinitions.usuarios = {
        title: "Usuarios",
        help: "Crea y mantiene los usuarios del sistema.",
        id: "id",
        columns: [
            ["nombreUsuario", "Usuario"],
            ["persona", "Persona"],
            ["perfiles", "Perfiles"],
            ["estado", "Estado", value => value === false ? "Inactivo" : "Activo"]
        ],
        fields: [
            { name: "nombreUsuario", label: "Usuario", required: true },
            { name: "pass", label: "Contrasena", type: "password", createOnlyHint: "Dejar vacio para no cambiar" },
            { name: "personaId", label: "Persona", type: "select", source: "personas", value: "id", text: item => [item.primerNombre, item.primerApellido, item.documento].filter(Boolean).join(" ") || `Persona ${item.id}` },
            { name: "perfilIds", label: "Perfiles", type: "multiselect", source: "perfiles", value: "id", text: "nombre" },
            { name: "estado", label: "Activo", type: "checkbox", defaultValue: true }
        ]
    };
</script>
