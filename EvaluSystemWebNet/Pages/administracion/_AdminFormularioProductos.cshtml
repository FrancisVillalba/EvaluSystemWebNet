<section class="admin-panel" data-module-panel="productos" hidden>
    <div class="admin-panel-header"><div><h2>Productos</h2><p>Productos disponibles para los pedidos.</p></div><button class="admin-primary new-record-button" type="button"><svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 5v14" /><path d="M5 12h14" /></svg><span>Nuevo</span></button></div>
    <form class="admin-form" data-admin-form>
        <label class="admin-field">Nombre<input data-field="nombre" type="text" required /></label>
        <label class="admin-field">Precio base<input data-field="precioBase" type="number" value="0" /></label>
        <label class="admin-field">Maquina<select data-field="maquinaId" data-source="maquinas"><option value="">Seleccionar</option></select></label>
        <label class="admin-check admin-check-field"><input data-field="estado" type="checkbox" checked />Activo</label><div class="admin-form-actions"><div class="admin-form-buttons"><button class="admin-secondary cancel-record-button" type="button">Cancelar</button><button class="admin-primary save-record-button" type="button"><span data-save-label>Crear</span></button></div></div>
    </form>
    <partial name="_AdminFormularioTabla" model='@(new[] { "Nombre", "Precio", "Maquina", "Estado" })' />
</section>
<script>
    window.adminModuleDefinitions = window.adminModuleDefinitions || {};
    window.adminModuleDefinitions.productos = {
                title: "Productos",
                help: "Productos disponibles para los pedidos.",
                id: "id",
                columns: [["nombre", "Nombre"], ["precioBase", "Precio"], ["maquina", "Maquina"], ["estado", "Estado", value => value ? "Activo" : "Inactivo"]],
                fields: [
                    { name: "nombre", label: "Nombre", required: true },
                    { name: "precioBase", label: "Precio base", type: "number", defaultValue: 0 },
                    { name: "maquinaId", label: "Maquina", type: "select", source: "maquinas", value: "id", text: "nombre" },
                    { name: "estado", label: "Activo", type: "checkbox", defaultValue: true }
                ]
            };
</script>