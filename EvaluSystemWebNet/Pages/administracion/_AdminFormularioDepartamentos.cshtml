<article class="admin-panel admin-screen" data-module-panel="departamentos" hidden>
    <header class="admin-panel-header admin-screen-header">
        <div>
            <h2>Departamentos</h2>
            <p>Crea y mantiene los departamentos disponibles para clientes y envios.</p>
        </div>
        <button class="admin-primary new-record-button" type="button">
            <svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 5v14" /><path d="M5 12h14" /></svg>
            <span>Nuevo</span>
        </button>
    </header>
    <form class="admin-form" data-admin-form>
        <div class="admin-screen-body">
            <label class="admin-field">Codigo<input data-field="id" type="number" /><span>Opcional, se genera si queda vacio</span></label>
            <label class="admin-field">Nombre<input data-field="nombre" type="text" required /></label>
        </div>
        <footer class="admin-screen-footer admin-form-actions">
            <div class="admin-form-checks">
                <label class="admin-check"><input data-field="estado" type="checkbox" checked />Activo</label>
            </div>
            <div class="admin-form-buttons">
                <button class="admin-secondary cancel-record-button" type="button">Cancelar</button>
                <button class="admin-primary save-record-button" type="button"><span data-save-label>Crear</span></button>
            </div>
        </footer>
    </form>
    <partial name="_AdminFormularioTabla" model='@(new[] { "Codigo", "Nombre", "Estado" })' />
</article>
<script>
    window.adminModuleDefinitions = window.adminModuleDefinitions || {};
    window.adminModuleDefinitions.departamentos = {
                title: "Departamentos",
                help: "Crea y mantiene los departamentos disponibles para clientes y envios.",
                id: "id",
                columns: [["id", "Codigo"], ["nombre", "Nombre"], ["estado", "Estado", value => value ? "Activo" : "Inactivo"]],
                fields: [
                    { name: "id", label: "Codigo", type: "number", createOnlyHint: "Opcional, se genera si queda vacio" },
                    { name: "nombre", label: "Nombre", required: true },
                    { name: "estado", label: "Activo", type: "checkbox", defaultValue: true }
                ]
            };
</script>
