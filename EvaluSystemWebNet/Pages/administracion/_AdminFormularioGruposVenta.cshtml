<section class="admin-panel" data-module-panel="gruposVenta" hidden>
    <div class="admin-panel-header"><div><h2>Grupo de ventas</h2><p>Asigna vendedores externos a un Team Leader.</p></div><button class="admin-primary new-record-button" type="button"><svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 5v14" /><path d="M5 12h14" /></svg><span>Nuevo</span></button></div>
    <form class="admin-form" data-admin-form>
        <label class="admin-field">Nombre<input data-field="nombre" type="text" required /></label>
        <label class="admin-field">Team Leader<select data-field="teamLeaderUsuarioId" data-source="usuarios" required><option value="">Seleccionar</option></select></label>
        <fieldset class="admin-field admin-multi-field" data-multiselect-field="vendedorUsuarioIds">
            <legend>Vendedores externos</legend>
            <div class="admin-multiselect" data-multiselect="vendedorUsuarioIds">
                <button class="admin-multiselect-button" type="button" data-multiselect-toggle aria-expanded="false"><span data-multiselect-summary>Seleccionar</span></button>
                <div class="admin-multiselect-values" data-multiselect-values></div>
                <div class="admin-multiselect-dropdown" data-multiselect-dropdown hidden><input class="admin-multiselect-search" type="search" placeholder="Buscar..." data-multiselect-search autocomplete="off"><div class="admin-multiselect-options" data-multiselect-options></div></div>
            </div>
        </fieldset>
        <div class="admin-form-actions"><div class="admin-form-checks"><label class="admin-check"><input data-field="estado" type="checkbox" checked />Activo</label></div><div class="admin-form-buttons"><button class="admin-secondary cancel-record-button" type="button">Cancelar</button><button class="admin-primary save-record-button" type="button"><span data-save-label>Crear</span></button></div></div>
    </form>
    <partial name="_AdminFormularioTabla" model='@(new[] { "Nombre", "Team Leader", "Vendedores", "Estado" })' />
</section>
<script>
    window.adminModuleDefinitions = window.adminModuleDefinitions || {};
    window.adminModuleDefinitions.gruposVenta = {
                title: "Grupo de ventas",
                help: "Asigna vendedores externos a un Team Leader.",
                id: "id",
                columns: [
                    ["nombre", "Nombre"],
                    ["teamLeader", "Team Leader"],
                    ["vendedores", "Vendedores", value => (value || []).map(item => item.vendedor).filter(Boolean).join(", ")],
                    ["estado", "Estado", value => value ? "Activo" : "Inactivo"]
                ],
                fields: [
                    { name: "nombre", label: "Nombre", required: true },
                    { name: "teamLeaderUsuarioId", label: "Team Leader", type: "select", source: "usuarios", value: "id", text: item => item.persona || item.nombreUsuario || `Usuario ${item.id}`, required: true },
                    { name: "vendedorUsuarioIds", label: "Vendedores externos", type: "multiselect", source: "usuarios", value: "id", text: item => item.persona || item.nombreUsuario || `Usuario ${item.id}` },
                    { name: "estado", label: "Activo", type: "checkbox", defaultValue: true }
                ]
            };
</script>