<section class="admin-panel" data-module-panel="productoComisiones" hidden>
    <div class="admin-panel-header"><div><h2>Comisiones por producto</h2><p>Define la comision por metro de cada producto segun el perfil del vendedor.</p></div><button class="admin-primary new-record-button" type="button"><svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 5v14" /><path d="M5 12h14" /></svg><span>Nuevo</span></button></div>
    <form class="admin-form" data-admin-form>
        <label class="admin-field">Producto<select data-field="productoId" data-source="productos" required><option value="">Seleccionar</option></select></label>
        <label class="admin-field">Perfil<select data-field="perfilId" data-source="perfiles" required><option value="">Seleccionar</option></select></label>
        <label class="admin-field">Monto por metro<input data-field="montoPorMetro" type="number" value="0" /></label>
        <label class="admin-field">Fecha desde<input data-field="fechaDesde" type="date" /></label>
        <label class="admin-field">Fecha hasta<input data-field="fechaHasta" type="date" /></label>
        <div class="admin-form-actions"><div class="admin-form-checks"><label class="admin-check"><input data-field="estado" type="checkbox" checked />Activo</label></div><div class="admin-form-buttons"><button class="admin-secondary cancel-record-button" type="button">Cancelar</button><button class="admin-primary save-record-button" type="button"><span data-save-label>Crear</span></button></div></div>
    </form>
    <partial name="_AdminFormularioTabla" model='@(new[] { "Producto", "Perfil", "Monto por metro", "Desde", "Hasta", "Estado" })' />
</section>
