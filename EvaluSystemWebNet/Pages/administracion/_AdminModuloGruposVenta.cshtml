gruposVenta: {
    title: "Grupo de ventas",
    help: "Asigna vendedores externos a un Team Leader.",
    id: "id",
    columns: [
        ["nombre", "Nombre"],
        ["teamLeader", "Team Leader"],
        ["vendedores", "Vendedores", value => (value || []).map(item => item.vendedor).filter(Boolean).join(", ")],
        ["estado", "Estado", value => value ? "Activo" : "Inactivo"]
    ],
    fields: [
        { name: "nombre", label: "Nombre", required: true },
        { name: "teamLeaderUsuarioId", label: "Team Leader", type: "select", source: "usuarios", value: "id", text: item => item.persona || item.nombreUsuario || `Usuario ${item.id}`, required: true },
        { name: "vendedorUsuarioIds", label: "Vendedores externos", type: "multiselect", source: "usuarios", value: "id", text: item => item.persona || item.nombreUsuario || `Usuario ${item.id}` },
        { name: "estado", label: "Activo", type: "checkbox", defaultValue: true }
    ]
},
