<section class="admin-panel" data-module-panel="transportadoras" hidden>
    <div class="admin-panel-header"><div><h2>Transportadoras</h2><p>Empresas de transporte para datos de envio.</p></div><button class="admin-primary new-record-button" type="button"><svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 5v14" /><path d="M5 12h14" /></svg><span>Nuevo</span></button></div>
    <form class="admin-form" data-admin-form>
        <label class="admin-field">Nombre<input data-field="nombre" type="text" required /></label>
        <label class="admin-field">Telefono<input data-field="telefono" type="text" /></label>
        <label class="admin-field">Direccion<input data-field="direccion" type="text" /></label>
        <label class="admin-field">Observacion<textarea data-field="observacion" rows="2"></textarea></label>
        <div class="admin-form-actions"><div class="admin-form-checks"><label class="admin-check"><input data-field="estado" type="checkbox" checked />Activo</label></div><div class="admin-form-buttons"><button class="admin-secondary cancel-record-button" type="button">Cancelar</button><button class="admin-primary save-record-button" type="button"><span data-save-label>Crear</span></button></div></div>
    </form>
    <partial name="_AdminFormularioTabla" model='@(new[] { "Nombre", "Telefono", "Direccion", "Estado" })' />
</section>
