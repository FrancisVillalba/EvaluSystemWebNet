@page
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Administracion";
    ViewData["ActiveMenu"] = "administracion";
    ViewData["ShellClass"] = "admin-shell";
}

<section class="admin-main">
    <div class="admin-workspace">
        <aside class="admin-modules" aria-label="Modulos de administracion">
            <button class="active" type="button" data-module="usuarios">Usuarios</button>
            <button type="button" data-module="personas">Personas</button>
            <button type="button" data-module="perfiles">Perfiles</button>
            <button type="button" data-module="accesos">Accesos</button>
            <button type="button" data-module="transportadoras">Transportadoras</button>
            <button type="button" data-module="productos">Productos</button>
            <button type="button" data-module="productoComisiones">Comisiones por producto</button>
            <button type="button" data-module="gruposVenta">Grupo de ventas</button>
            <button type="button" data-module="maquinas">Tipos de maquina</button>
            <button type="button" data-module="formasPago">Formas de pago</button>
            <button type="button" data-module="estadosPago">Estados de pago</button>
            <button type="button" data-module="estadosVenta">Estados de venta</button>
            <button type="button" data-module="tiposDocumento">Tipos documento</button>
            <button type="button" data-module="tiposCliente">Tipos cliente</button>
            <button type="button" data-module="configuraciones">Configuraciones</button>
            <button type="button" data-module="departamentos">Departamentos</button>
            <button type="button" data-module="ciudades">Ciudades</button>
        </aside>

        <section id="crud-panel" class="admin-panel">
            <div class="admin-panel-header">
                <div>
                    <h2 id="module-title">Usuarios</h2>
                    <p id="module-help">Crea y mantiene los usuarios del sistema.</p>
                </div>
                <button id="new-record-button" class="admin-primary" type="button">
                    <svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M12 5v14" />
                        <path d="M5 12h14" />
                    </svg>
                    <span>Nuevo</span>
                </button>
            </div>

            <div id="admin-form" class="admin-form"></div>

            <div class="admin-list-toolbar">
                <label>
                    Buscar
                    <input id="admin-search" type="search" placeholder="Buscar en este modulo" autocomplete="off" />
                </label>
                <button id="admin-search-button" class="admin-primary" type="button">Buscar</button>
                <button id="admin-clear-search-button" class="admin-secondary" type="button">Limpiar</button>
            </div>

            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead id="admin-table-head"></thead>
                    <tbody id="admin-table-body"></tbody>
                </table>
            </div>
            <div id="admin-pagination" class="admin-pagination" aria-live="polite"></div>
        </section>

        <section id="access-panel" class="admin-panel" hidden>
            <div class="admin-panel-header">
                <div>
                    <h2>Accesos por perfil</h2>
                    <p>Selecciona un perfil y marca que formularios puede usar.</p>
                </div>
            </div>

            <div class="admin-access-filter">
                <label for="access-profile">
                    Perfil
                    <select id="access-profile"></select>
                </label>
            </div>

            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Formulario</th>
                            <th>Ver</th>
                            <th>Crear</th>
                            <th>Editar</th>
                            <th>Eliminar</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="access-table-body"></tbody>
                </table>
            </div>
        </section>
    </div>
</section>

@section Scripts {
    <script>
        const modules = {
            @await Html.PartialAsync("_AdminModuloUsuarios")
            @await Html.PartialAsync("_AdminModuloPersonas")
            @await Html.PartialAsync("_AdminModuloPerfiles")
            @await Html.PartialAsync("_AdminModuloTransportadoras")
            @await Html.PartialAsync("_AdminModuloProductos")
            @await Html.PartialAsync("_AdminModuloProductoComisiones")
            @await Html.PartialAsync("_AdminModuloGruposVenta")
            @await Html.PartialAsync("_AdminModuloMaquinas")
            @await Html.PartialAsync("_AdminModuloFormasPago")
            @await Html.PartialAsync("_AdminModuloEstadosPago")
            @await Html.PartialAsync("_AdminModuloTiposDocumento")
            @await Html.PartialAsync("_AdminModuloTiposCliente")
            @await Html.PartialAsync("_AdminModuloEstadosVenta")
            @await Html.PartialAsync("_AdminModuloConfiguraciones")
            @await Html.PartialAsync("_AdminModuloDepartamentos")
            @await Html.PartialAsync("_AdminModuloCiudades")
        };

        const state = {
            module: "usuarios",
            records: [],
            editing: null,
            options: { perfiles: [], personas: [], maquinas: [], departamentos: [], tiposDocumento: [], productos: [], usuarios: [] },
            formularios: [],
            permisos: [],
            search: "",
            page: 1,
            pageSize: 10,
            totalItems: 0,
            totalPages: 1
        };

        const crudPanel = document.getElementById("crud-panel");
        const accessPanel = document.getElementById("access-panel");
        const moduleTitle = document.getElementById("module-title");
        const moduleHelp = document.getElementById("module-help");
        const formHost = document.getElementById("admin-form");
        const tableHead = document.getElementById("admin-table-head");
        const tableBody = document.getElementById("admin-table-body");
        const adminSearch = document.getElementById("admin-search");
        const adminPagination = document.getElementById("admin-pagination");
        const newButton = document.getElementById("new-record-button");
        const accessProfile = document.getElementById("access-profile");
        const accessTableBody = document.getElementById("access-table-body");

        function simpleStringModule(title, help) {
            return {
                title,
                help,
                id: "id",
                columns: [["id", "Codigo"], ["nombre", "Nombre"], ["estado", "Estado", value => value === false ? "Inactivo" : "Activo"]],
                fields: [
                    { name: "id", label: "Codigo", required: true },
                    { name: "nombre", label: "Nombre", required: true },
                    { name: "estado", label: "Activo", type: "checkbox", defaultValue: true }
                ]
            };
        }

        function simpleNumberModule(title, help) {
            return {
                title,
                help,
                id: "id",
                columns: [["nombre", "Nombre"], ["estado", "Estado", value => value ? "Activo" : "Inactivo"]],
                fields: [
                    { name: "nombre", label: "Nombre", required: true },
                    { name: "estado", label: "Activo", type: "checkbox", defaultValue: true }
                ]
            };
        }

        function escapeHtml(value) {
            return String(value ?? "").replace(/[&<>"']/g, character => ({
                "&": "&amp;",
                "<": "&lt;",
                ">": "&gt;",
                "\"": "&quot;",
                "'": "&#039;"
            })[character]);
        }

        function appIcon(name) {
            const paths = {
                cancel: `<path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>`,
                save: `<path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2Z"></path><path d="M17 21v-8H7v8"></path><path d="M7 3v5h8"></path>`,
                plus: `<path d="M12 5v14"></path><path d="M5 12h14"></path>`
            };

            return `<svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">${paths[name] || ""}</svg>`;
        }

        function fieldValue(record, key) {
            return key.split(".").reduce((value, part) => value?.[part], record);
        }

        function formatDate(value) {
            if (!value) {
                return "";
            }

            const date = new Date(value);
            return Number.isNaN(date.getTime()) ? value : date.toLocaleDateString("es-PY");
        }

        function formatValue(record, column) {
            const [key, , formatter] = column;
            const value = fieldValue(record, key);
            return formatter ? formatter(value, record) : value;
        }

        function optionText(item, field) {
            return typeof field.text === "function" ? field.text(item) : item[field.text || "nombre"];
        }

        function optionValue(item, field) {
            return item[field.value];
        }

        function renderModule() {
            const config = modules[state.module];
            moduleTitle.textContent = config.title;
            moduleHelp.textContent = config.help;
            newButton.hidden = Boolean(config.readonly);
            renderForm();
            renderTable();
        }

        function renderForm() {
            const config = modules[state.module];
            if (config.readonly) {
                formHost.innerHTML = "";
                return;
            }

            const record = state.editing || {};
            const isEditingRecord = state.editing?.[config.id] !== undefined && state.editing?.[config.id] !== null;
            const actionFields = config.fields.filter(field => field.type === "checkbox");
            const inputFields = config.fields.filter(field => field.type !== "checkbox");
            formHost.innerHTML = `
                ${inputFields.map(field => renderField(field, record)).join("")}
                <div class="admin-form-actions">
                    <div class="admin-form-checks">
                        ${actionFields.map(field => renderField(field, record)).join("")}
                    </div>
                    <div class="admin-form-buttons">
                        <button class="admin-secondary" type="button" id="cancel-record-button">${appIcon("cancel")}<span>Cancelar</span></button>
                        <button class="admin-primary" type="button" id="save-record-button">${appIcon(isEditingRecord ? "save" : "plus")}<span>${isEditingRecord ? "Guardar" : "Crear"}</span></button>
                    </div>
                </div>`;

            document.getElementById("cancel-record-button").addEventListener("click", () => {
                state.editing = null;
                renderForm();
            });
            document.getElementById("save-record-button").addEventListener("click", saveRecord);
        }

        function renderField(field, record) {
            const value = record[field.name] ?? field.defaultValue ?? "";
            if (field.type === "checkbox") {
                const checked = value === true || value === "true" || value === "";
                return `<label class="admin-check"><input data-field="${field.name}" type="checkbox" ${checked ? "checked" : ""} />${escapeHtml(field.label)}</label>`;
            }

            if (field.type === "select") {
                const items = state.options[field.source] || [];
                return `
                    <label class="admin-field">${escapeHtml(field.label)}
                        <select data-field="${field.name}" ${field.required ? "required" : ""}>
                            <option value="">Seleccionar</option>
                            ${items.map(item => `<option value="${escapeHtml(item[field.value])}" ${String(item[field.value]) === String(value) ? "selected" : ""}>${escapeHtml(optionText(item, field))}</option>`).join("")}
                        </select>
                    </label>`;
            }

            if (field.type === "multiselect") {
                const items = state.options[field.source] || [];
                const selected = new Set((record[field.name] || []).map(value => String(value)));
                const selectedItems = items.filter(item => selected.has(String(optionValue(item, field))));
                const summary = selectedItems.length === 0
                    ? "Seleccionar"
                    : `${selectedItems.length} seleccionado${selectedItems.length === 1 ? "" : "s"}`;
                return `
                    <fieldset class="admin-field admin-multi-field">
                        <legend>${escapeHtml(field.label)}</legend>
                        <div class="admin-multiselect" data-multiselect="${field.name}">
                            <button class="admin-multiselect-button" type="button" data-multiselect-toggle aria-expanded="false">
                                <span>${escapeHtml(summary)}</span>
                            </button>
                            <div class="admin-multiselect-values" data-multiselect-values>
                                ${selectedItems.map(item => `
                                    <span class="admin-multiselect-chip" data-chip-value="${escapeHtml(optionValue(item, field))}">
                                        ${escapeHtml(optionText(item, field))}
                                        <button type="button" data-remove-multiselect="${field.name}" data-value="${escapeHtml(optionValue(item, field))}" aria-label="Quitar ${escapeHtml(optionText(item, field))}">x</button>
                                    </span>
                                `).join("")}
                            </div>
                            <div class="admin-multiselect-dropdown" data-multiselect-dropdown hidden>
                                <input class="admin-multiselect-search" type="search" placeholder="Buscar..." data-multiselect-search autocomplete="off">
                                <div class="admin-multiselect-options" data-multiselect-options>
                                    ${items.map(item => {
                                        const value = optionValue(item, field);
                                        const text = optionText(item, field);
                                        return `
                                            <button class="admin-multiselect-option ${selected.has(String(value)) ? "is-selected" : ""}" type="button" data-toggle-multiselect="${field.name}" data-value="${escapeHtml(value)}" data-search="${escapeHtml(text).toLowerCase()}">
                                                <span>${escapeHtml(text)}</span>
                                                <span class="admin-multiselect-mark">${selected.has(String(value)) ? "Seleccionado" : ""}</span>
                                            </button>`;
                                    }).join("")}
                                </div>
                            </div>
                            ${selectedItems.map(item => `<input data-field="${field.name}" type="hidden" value="${escapeHtml(optionValue(item, field))}">`).join("")}
                        </div>
                    </fieldset>`;
            }

            if (field.type === "textarea") {
                return `<label class="admin-field">${escapeHtml(field.label)}<textarea data-field="${field.name}" rows="2">${escapeHtml(value)}</textarea></label>`;
            }

            const hint = field.createOnlyHint ? `<span>${escapeHtml(field.createOnlyHint)}</span>` : "";
            return `<label class="admin-field">${escapeHtml(field.label)}<input data-field="${field.name}" type="${field.type || "text"}" value="${escapeHtml(value)}" ${field.required ? "required" : ""} />${hint}</label>`;
        }

        function renderTable() {
            const config = modules[state.module];
            tableHead.innerHTML = `<tr>${config.columns.map(([, label]) => `<th>${escapeHtml(label)}</th>`).join("")}<th>Acciones</th></tr>`;
            tableBody.innerHTML = state.records.length ? state.records.map(record => `
                <tr>
                    ${config.columns.map(column => `<td>${escapeHtml(formatValue(record, column))}</td>`).join("")}
                    <td>
                        <div class="admin-row-actions">
                            ${config.readonly ? "" : `<button type="button" onclick="editRecord('${escapeHtml(record[config.id])}')">Editar</button><button class="danger" type="button" onclick="deleteRecord('${escapeHtml(record[config.id])}')">Eliminar</button>`}
                        </div>
                    </td>
                </tr>`).join("") : `<tr><td colspan="${config.columns.length + 1}">No hay registros para los filtros seleccionados.</td></tr>`;
            renderAdminPagination();
        }

        function renderAdminPagination() {
            if (state.module === "accesos") {
                adminPagination.innerHTML = "";
                return;
            }

            adminPagination.innerHTML = `
                <span>Pagina ${state.page} de ${state.totalPages}</span>
                <div class="admin-pagination-actions">
                    <label>
                        <span>Registros</span>
                        <select id="admin-page-size">
                            <option value="10" ${state.pageSize === 10 ? "selected" : ""}>10</option>
                            <option value="20" ${state.pageSize === 20 ? "selected" : ""}>20</option>
                            <option value="50" ${state.pageSize === 50 ? "selected" : ""}>50</option>
                        </select>
                    </label>
                    <button type="button" data-admin-page="previous" ${state.page <= 1 ? "disabled" : ""}>Anterior</button>
                    <span class="admin-pagination-current">${state.page}</span>
                    <button type="button" data-admin-page="next" ${state.page >= state.totalPages ? "disabled" : ""}>Siguiente</button>
                </div>`;
        }

        function collectPayload() {
            const config = modules[state.module];
            const payload = {};
            for (const field of config.fields) {
                if (field.type === "multiselect") {
                    payload[field.name] = Array.from(formHost.querySelectorAll(`[data-field="${field.name}"]`))
                        .map(item => coerceOptionValue(item.value));
                    continue;
                }

                const input = formHost.querySelector(`[data-field="${field.name}"]`);
                if (!input) {
                    continue;
                }

                if (field.type === "checkbox") {
                    payload[field.name] = input.checked;
                } else if (field.type === "number") {
                    payload[field.name] = input.value === "" ? null : Number(input.value);
                } else if (field.type === "select") {
                    payload[field.name] = input.value === "" ? null : coerceOptionValue(input.value);
                } else {
                    payload[field.name] = input.value.trim() || null;
                }
            }

            return payload;
        }

        function coerceOptionValue(value) {
            return /^-?\d+$/.test(value) ? Number(value) : value;
        }

        function closeMultiselects(except = null) {
            formHost.querySelectorAll("[data-multiselect]").forEach(control => {
                if (control === except) {
                    return;
                }

                control.querySelector("[data-multiselect-dropdown]")?.setAttribute("hidden", "");
                control.querySelector("[data-multiselect-toggle]")?.setAttribute("aria-expanded", "false");
            });
        }

        formHost.addEventListener("click", event => {
            const toggle = event.target.closest("[data-multiselect-toggle]");
            if (toggle) {
                const control = toggle.closest("[data-multiselect]");
                const dropdown = control.querySelector("[data-multiselect-dropdown]");
                const isOpen = !dropdown.hasAttribute("hidden");
                closeMultiselects(control);
                dropdown.toggleAttribute("hidden", isOpen);
                toggle.setAttribute("aria-expanded", isOpen ? "false" : "true");
                if (!isOpen) {
                    control.querySelector("[data-multiselect-search]")?.focus();
                }
                return;
            }

            const option = event.target.closest("[data-toggle-multiselect]");
            if (option) {
                toggleMultiselectValue(option.dataset.toggleMultiselect, option.dataset.value);
                return;
            }

            const remove = event.target.closest("[data-remove-multiselect]");
            if (remove) {
                toggleMultiselectValue(remove.dataset.removeMultiselect, remove.dataset.value);
            }
        });

        formHost.addEventListener("input", event => {
            if (!event.target.matches("[data-multiselect-search]")) {
                return;
            }

            const control = event.target.closest("[data-multiselect]");
            const query = event.target.value.trim().toLowerCase();
            control.querySelectorAll("[data-toggle-multiselect]").forEach(option => {
                option.hidden = query && !option.dataset.search.includes(query);
            });
        });

        document.addEventListener("click", event => {
            if (!event.target.closest("[data-multiselect]")) {
                closeMultiselects();
            }
        });

        function toggleMultiselectValue(fieldName, value) {
            const config = modules[state.module];
            const current = collectPayload();
            const field = config.fields.find(item => item.name === fieldName);
            const record = { ...(state.editing || {}), ...current };
            const values = new Set((record[fieldName] || []).map(item => String(item)));
            values.has(String(value)) ? values.delete(String(value)) : values.add(String(value));
            record[fieldName] = Array.from(values).map(item => coerceOptionValue(item));
            state.editing = state.editing ? { ...state.editing, ...record } : record;
            renderForm();

            const control = formHost.querySelector(`[data-multiselect="${field.name}"]`);
            control?.querySelector("[data-multiselect-dropdown]")?.removeAttribute("hidden");
            control?.querySelector("[data-multiselect-toggle]")?.setAttribute("aria-expanded", "true");
            control?.querySelector("[data-multiselect-search]")?.focus();
        }

        async function loadRecords() {
            if (state.module === "accesos") {
                await loadAccess();
                return;
            }

            await withAppLoading("Cargando datos...", async function () {
                const params = new URLSearchParams({
                    page: String(state.page),
                    pageSize: String(state.pageSize)
                });
                if (state.search) {
                    params.set("search", state.search);
                }

                const response = await fetch(`/api/administracion/${state.module}?${params.toString()}`);
                if (!response.ok) {
                    const error = await response.json().catch(() => null);
                    showToast(error?.message || "No se pudo cargar el modulo.", "error");
                    return;
                }

                const result = await response.json();
                if (Array.isArray(result)) {
                    state.records = result;
                    state.totalItems = result.length;
                    state.totalPages = 1;
                    state.page = 1;
                } else {
                    state.records = result.items || [];
                    state.page = result.page || state.page;
                    state.pageSize = result.pageSize || state.pageSize;
                    state.totalItems = result.totalItems || 0;
                    state.totalPages = Math.max(result.totalPages || 1, 1);
                }

                state.editing = null;
                renderModule();
            });
        }

        async function saveRecord() {
            const config = modules[state.module];
            const payload = collectPayload();
            const id = state.editing?.[config.id];
            const isEditing = id !== undefined && id !== null;
            const response = await withAppLoading("Guardando...", async function () {
                return await fetch(isEditing ? `/api/administracion/${state.module}/${encodeURIComponent(id)}` : `/api/administracion/${state.module}`, {
                    method: isEditing ? "PUT" : "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });
            });

            if (!response.ok) {
                const error = await response.json().catch(() => null);
                showToast(error?.message || "No se pudo guardar.", "error");
                return;
            }

            showToast("Registro guardado correctamente.", "success");
            await refreshOptions();
            await loadRecords();
        }

        window.editRecord = function (id) {
            const config = modules[state.module];
            const record = state.records.find(record => String(record[config.id]) === String(id)) || null;
            state.editing = state.module === "gruposVenta" && record
                ? { ...record, vendedorUsuarioIds: (record.vendedores || []).map(item => item.vendedorUsuarioId) }
                : record;
            renderForm();
        };

        window.deleteRecord = async function (id) {
            const confirmed = await showConfirmDialog({
                title: "Eliminar registro",
                message: "Seguro que desea eliminar este registro?",
                confirmText: "Eliminar",
                cancelText: "Cancelar",
                tone: "danger"
            });

            if (!confirmed) {
                return;
            }

            const response = await withAppLoading("Eliminando...", async function () {
                return await fetch(`/api/administracion/${state.module}/${encodeURIComponent(id)}`, { method: "DELETE" });
            });

            if (!response.ok) {
                const error = await response.json().catch(() => null);
                showToast(error?.message || "No se pudo eliminar.", "error");
                return;
            }

            showToast("Registro eliminado correctamente.", "success");
            await refreshOptions();
            await loadRecords();
        };

        async function refreshOptions() {
            const response = await fetch("/api/administracion/opciones");
            if (response.ok) {
                state.options = await response.json();
            }
        }

        async function loadAccess() {
            crudPanel.hidden = true;
            accessPanel.hidden = false;
            await refreshOptions();
            accessProfile.innerHTML = `<option value="">Seleccionar</option>` + state.options.perfiles.map(profile => `<option value="${profile.id}">${escapeHtml(profile.nombre)}</option>`).join("");
            accessTableBody.innerHTML = "";
        }

        async function loadAccessTables() {
            const profileId = Number(accessProfile.value);
            if (!profileId) {
                accessTableBody.innerHTML = "";
                return;
            }

            await withAppLoading("Cargando accesos...", async function () {
                const [formsResponse, permissionsResponse] = await Promise.all([
                    fetch("/api/administracion/permisos/formularios"),
                    fetch(`/api/administracion/permisos/perfil/${profileId}`)
                ]);

                state.formularios = formsResponse.ok ? await formsResponse.json() : [];
                state.permisos = permissionsResponse.ok ? await permissionsResponse.json() : [];
                renderAccessTable(profileId);
            });
        }

        function renderAccessTable(profileId) {
            const forms = [...state.formularios].sort((a, b) => {
                const parentA = a.formularioPadre || "";
                const parentB = b.formularioPadre || "";
                return parentA.localeCompare(parentB) || a.orden - b.orden || a.nombre.localeCompare(b.nombre);
            });

            accessTableBody.innerHTML = forms.map(form => {
                const permission = state.permisos.find(item => item.formularioId === form.id) || {};
                const displayName = form.formularioPadre ? `${form.formularioPadre} > ${form.nombre}` : form.nombre;
                return `
                    <tr data-form="${form.id}">
                        <td>${escapeHtml(displayName)}</td>
                        ${["puedeVer", "puedeCrear", "puedeEditar", "puedeEliminar"].map(key => `<td><input type="checkbox" data-permission="${key}" ${permission[key] ? "checked" : ""}></td>`).join("")}
                        <td><button type="button" onclick="saveAccess(${profileId}, ${form.id})">Guardar</button></td>
                    </tr>`;
            }).join("");
        }

        window.saveAccess = async function (profileId, formularioId) {
            const row = accessTableBody.querySelector(`[data-form="${formularioId}"]`);
            const payload = {
                perfilId: profileId,
                formularioId,
                puedeVer: row.querySelector('[data-permission="puedeVer"]').checked,
                puedeCrear: row.querySelector('[data-permission="puedeCrear"]').checked,
                puedeEditar: row.querySelector('[data-permission="puedeEditar"]').checked,
                puedeEliminar: row.querySelector('[data-permission="puedeEliminar"]').checked
            };

            const response = await withAppLoading("Guardando acceso...", async function () {
                return await fetch("/api/administracion/permisos/perfil-formulario", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });
            });

            if (!response.ok) {
                const error = await response.json().catch(() => null);
                showToast(error?.message || "No se pudo guardar el acceso.", "error");
                return;
            }

            showToast("Acceso guardado correctamente.", "success");
            await loadAccessTables();
        };

        document.querySelectorAll(".admin-modules button").forEach(button => {
            button.addEventListener("click", async function () {
                document.querySelectorAll(".admin-modules button").forEach(item => item.classList.remove("active"));
                button.classList.add("active");
                state.module = button.dataset.module;
                state.search = "";
                state.page = 1;
                adminSearch.value = "";
                crudPanel.hidden = state.module === "accesos";
                accessPanel.hidden = state.module !== "accesos";
                await loadRecords();
            });
        });

        document.getElementById("admin-search-button").addEventListener("click", async () => {
            state.search = adminSearch.value.trim();
            state.page = 1;
            await loadRecords();
        });

        document.getElementById("admin-clear-search-button").addEventListener("click", async () => {
            adminSearch.value = "";
            state.search = "";
            state.page = 1;
            await loadRecords();
        });

        adminSearch.addEventListener("keydown", async event => {
            if (event.key !== "Enter") {
                return;
            }

            state.search = adminSearch.value.trim();
            state.page = 1;
            await loadRecords();
        });

        adminPagination.addEventListener("click", async event => {
            const button = event.target.closest("[data-admin-page]");
            if (!button) {
                return;
            }

            state.page += button.dataset.adminPage === "next" ? 1 : -1;
            await loadRecords();
        });

        adminPagination.addEventListener("change", async event => {
            const select = event.target.closest("#admin-page-size");
            if (!select) {
                return;
            }

            state.pageSize = Number(select.value);
            state.page = 1;
            await loadRecords();
        });

        newButton.addEventListener("click", () => {
            state.editing = null;
            renderForm();
        });
        accessProfile.addEventListener("change", loadAccessTables);

        refreshOptions().then(loadRecords);
    </script>
}
