<section class="admin-panel" data-module-panel="estadosPago" hidden>
    <div class="admin-panel-header"><div><h2>Estados de pago</h2><p>Catalogo de estados de pago.</p></div><button class="admin-primary new-record-button" type="button"><svg class="app-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 5v14" /><path d="M5 12h14" /></svg><span>Nuevo</span></button></div>
    <form class="admin-form" data-admin-form><label class="admin-field">Codigo<input data-field="id" type="text" required /></label><label class="admin-field">Nombre<input data-field="nombre" type="text" required /></label><label class="admin-check admin-check-field"><input data-field="estado" type="checkbox" checked />Activo</label><div class="admin-form-actions"><div class="admin-form-buttons"><button class="admin-secondary cancel-record-button" type="button">Cancelar</button><button class="admin-primary save-record-button" type="button"><span data-save-label>Crear</span></button></div></div></form>
    <partial name="_AdminFormularioTabla" model='@(new[] { "Codigo", "Nombre", "Estado" })' />
</section>
<script>
    window.adminModuleDefinitions = window.adminModuleDefinitions || {};
    window.adminModuleDefinitions.estadosPago = {
    title: "Estados de pago",
    help: "Catalogo de estados de pago.",
    id: "id",
    columns: [["id", "Codigo"], ["nombre", "Nombre"], ["estado", "Estado", value => value === false ? "Inactivo" : "Activo"]],
    fields: [
        { name: "id", label: "Codigo", required: true },
        { name: "nombre", label: "Nombre", required: true },
        { name: "estado", label: "Activo", type: "checkbox", defaultValue: true }
    ]
};
</script>